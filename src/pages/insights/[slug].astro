---
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import Button from '../../components/Button.astro';
import { articles, formatDate } from '../../data/insights';

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug }, props: { a } }));
}
const { a } = Astro.props;
const related = articles.filter((x) => x.slug !== a.slug).slice(0, 3);
---
<Base title={a.title} description={a.excerpt} image={a.image}>
  <article class="art">
    <div class="container container--narrow">
      <a class="art__back" href="/insights"><span aria-hidden="true">←</span> Todos os insights</a>
      <span class="art__cat" data-reveal>{a.category}</span>
      <h1 class="display art__title" data-reveal style="--reveal-delay:80ms">{a.title}</h1>
      <p class="lede art__excerpt" data-reveal style="--reveal-delay:140ms">{a.excerpt}</p>
      <div class="art__meta" data-reveal style="--reveal-delay:200ms">
        <span>{a.author}</span>
        <span class="art__dot">·</span>
        <time datetime={a.date}>{formatDate(a.date)}</time>
        <span class="art__dot">·</span>
        <span>{a.readingTime} min de leitura</span>
      </div>
    </div>

    <figure class="container container--narrow art__hero" data-reveal>
      <img src={a.image} alt={a.title} width="1600" height="900" fetchpriority="high" decoding="async" />
    </figure>

    <div class="container container--narrow art__body">
      {a.body.map((section) => (
        <section class="art__section" data-reveal>
          {section.heading && <h2 class="h2 art__heading">{section.heading}</h2>}
          {section.paragraphs.map((para) => <p>{para}</p>)}
        </section>
      ))}

      <div class="art__cta" data-reveal>
        <p>Tem um imóvel distinto para vender no Porto?</p>
        <Button href="/#vender" variant="ghost-dark" arrow>Pedir avaliação</Button>
      </div>
    </div>

    {related.length > 0 && (
      <div class="container art__related">
        <h2 class="h3 art__related-title" data-reveal>Continuar a ler</h2>
        <div class="art__related-grid">
          {related.map((r) => <BlogCard article={r} />)}
        </div>
      </div>
    )}
  </article>
</Base>

<style>
  .art { padding: calc(var(--nav-h) + 40px) 0 clamp(70px, 9vw, 130px); }
  .art__back {
    display: inline-flex; align-items: center; gap: 9px; text-decoration: none; color: var(--ink-60);
    font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; transition: color var(--t-fast);
  }
  .art__back span { color: var(--gold-deep); transition: transform var(--t-fast); }
  .art__back:hover { color: var(--gold-deep); }
  .art__back:hover span { transform: translateX(-3px); }

  .art__cat {
    display: inline-block; margin-top: 26px; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--navy-ink); background: var(--gold-light); padding: 6px 13px; border-radius: 2px; font-weight: 500;
  }
  .art__title { font-size: clamp(36px, 4.6vw, 64px); margin-top: 20px; }
  .art__excerpt { margin-top: 22px; font-size: clamp(18px, 1.6vw, 22px); }
  .art__meta {
    display: flex; align-items: center; flex-wrap: wrap; gap: 10px; margin-top: 24px;
    font-size: 13.5px; color: var(--ink-40); letter-spacing: 0.03em;
  }

  /* Featured image — contained to the article column, never full-viewport. */
  .art__hero {
    margin: clamp(32px, 4vw, 52px) auto 0; border-radius: var(--radius-lg); overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .art__hero img {
    display: block; width: 100%; aspect-ratio: 3 / 2;
    max-height: min(60vh, 540px); object-fit: cover;
  }

  .art__body { margin-top: clamp(36px, 4vw, 56px); }
  .art__section { margin-bottom: 8px; }
  .art__heading { font-size: clamp(24px, 2.4vw, 32px); margin: 36px 0 16px; }
  .art__body p { font-size: 18px; line-height: 1.8; color: var(--ink-60); margin: 0 0 20px; }

  .art__cta {
    margin-top: 48px; padding: clamp(28px, 3vw, 40px); border: 1px solid var(--hairline-gold);
    border-radius: var(--radius-lg); background: var(--cream-soft);
    display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;
  }
  .art__cta p { margin: 0; font-family: var(--font-serif); font-size: 22px; color: var(--navy); }

  .art__related { margin-top: clamp(64px, 8vw, 110px); }
  .art__related-title { margin-bottom: clamp(24px, 3vw, 40px); }
  .art__related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(18px, 2vw, 30px); }
  @media (max-width: 980px) { .art__related-grid { grid-template-columns: 1fr; } }
</style>
