---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import Icon from '../../components/Icon.astro';
import CatalogCard from '../../components/CatalogCard.astro';
import heroImg from '../../assets/porto-noite-douro.png';
import { properties, categoryOf } from '../../data/properties';
import { neighborhoods } from '../../data/site';

const cells = properties.map((p) => ({ p, cat: categoryOf(p) }));
const tipos = ['Apartamento', 'Moradia', 'Penthouse', 'Loft'];
const precos = [
  { value: 'all', label: 'Qualquer' },
  { value: '0-1000000', label: 'Até 1 M€' },
  { value: '1000000-2000000', label: '1 – 2 M€' },
  { value: '2000000-', label: '+2 M€' },
];
const quartos = [
  { value: 'all', label: 'Qualquer' },
  { value: '1', label: '1+' },
  { value: '2', label: '2+' },
  { value: '3', label: '3+' },
  { value: '4', label: '4+' },
];
---
<Base
  title="Imóveis"
  description="A coleção de imóveis distintos da RE/MAX Collection Vintage no Porto — Foz, Boavista, Ribeira e Cedofeita. Uma seleção exclusiva de propriedades de prestígio."
>
  <section class="chero">
    <div class="chero__bg" aria-hidden="true">
      <Image
        class="chero__img"
        src={heroImg}
        alt=""
        widths={[760, 1140, 1693]}
        sizes="(max-width: 720px) 100vw, 62vw"
        loading="eager"
        fetchpriority="high"
      />
      <span class="chero__grad"></span>
    </div>

    <div class="chero__inner">
      <nav class="chero__crumb" aria-label="Caminho">
        <a href="/">Início</a>
        <span class="chero__crumb-sep" aria-hidden="true">/</span>
        <span aria-current="page">Imóveis</span>
      </nav>
      <h1 class="chero__title" data-reveal>Catálogo de Imóveis</h1>
      <span class="gold-rule chero__line" data-reveal="rule"></span>
      <p class="chero__lede" data-reveal style="--reveal-delay:160ms">
        Descubra uma seleção exclusiva de imóveis de prestígio no Porto e Douro, escolhidos com rigor e dedicação.
      </p>
    </div>
  </section>

  <section class="catalog">
    <div class="container">
      <div class="cfilters" data-filters data-reveal>
        <div class="cfcol">
          <div class="cfgroup">
            <span class="cflabel"><Icon name="pin" size={13} stroke={1.7} /> Zona</span>
            <div class="cfpills">
              <button type="button" class="chip is-active" data-group="zona" data-value="all" aria-pressed="true">Todas</button>
              {neighborhoods.map((n) => (
                <button type="button" class="chip" data-group="zona" data-value={n.slug} aria-pressed="false">{n.name}</button>
              ))}
            </div>
          </div>
          <div class="cfgroup">
            <span class="cflabel"><Icon name="diamond" size={13} stroke={1.7} /> Preço</span>
            <div class="cfpills">
              {precos.map((o) => (
                <button type="button" class:list={['chip', { 'is-active': o.value === 'all' }]} data-group="preco" data-value={o.value} aria-pressed={o.value === 'all' ? 'true' : 'false'}>{o.label}</button>
              ))}
            </div>
          </div>
        </div>

        <div class="cfcol cfcol--div">
          <div class="cfgroup">
            <span class="cflabel"><Icon name="building" size={13} stroke={1.7} /> Tipo</span>
            <div class="cfpills">
              <button type="button" class="chip is-active" data-group="tipo" data-value="all" aria-pressed="true">Todos</button>
              {tipos.map((t) => (
                <button type="button" class="chip" data-group="tipo" data-value={t} aria-pressed="false">{t}</button>
              ))}
            </div>
          </div>
          <div class="cfgroup">
            <span class="cflabel"><Icon name="bed" size={13} stroke={1.7} /> Quartos</span>
            <div class="cfpills">
              {quartos.map((o) => (
                <button type="button" class:list={['chip', { 'is-active': o.value === 'all' }]} data-group="quartos" data-value={o.value} aria-pressed={o.value === 'all' ? 'true' : 'false'}>{o.label}</button>
              ))}
            </div>
          </div>
        </div>

        <div class="cfcol cfcol--div cfcol--meta">
          <p class="cfcount" aria-live="polite">
            <b class="cfcount__n" data-count>{properties.length}</b> <span data-count-word>imóveis</span> encontrados
          </p>
          <label class="cfsort">
            <span class="cfsort__lab">Ordenar por</span>
            <span class="cfsort__field">
              <select data-sort aria-label="Ordenar imóveis">
                <option value="recentes">Mais recentes</option>
                <option value="preco-desc">Preço — mais alto</option>
                <option value="preco-asc">Preço — mais baixo</option>
                <option value="area-desc">Área — maior</option>
              </select>
              <Icon name="chevron" size={15} stroke={1.8} />
            </span>
          </label>
        </div>
      </div>

      <div class="cgrid" data-grid>
        {cells.map(({ p, cat }, i) => (
          <div
            class="cgrid__cell"
            data-zona={p.neighborhood}
            data-cat={cat}
            data-price={p.price ?? ''}
            data-beds={p.beds}
            data-area={p.area}
            data-order={i}
          >
            <CatalogCard property={p} index={i} />
          </div>
        ))}
      </div>
      <p class="cgrid__empty" data-empty hidden>
        Não encontrámos imóveis para esta combinação. <button type="button" class="btn-link" data-reset>Limpar filtros</button>
      </p>
    </div>
  </section>
</Base>

<style>
  /* ---------- Hero band ---------- */
  .chero {
    position: relative; overflow: hidden; background: var(--navy-ink); color: var(--cream);
    padding: calc(var(--nav-h) + clamp(36px, 5vw, 60px)) var(--gutter) clamp(58px, 6vw, 92px);
  }
  .chero__bg { position: absolute; inset: 0; z-index: 0; }
  .chero__img {
    position: absolute; right: 0; top: 0; height: 100%; width: 62%;
    object-fit: cover; object-position: center 40%;
  }
  .chero__grad {
    position: absolute; inset: 0;
    background: linear-gradient(
      to right,
      var(--navy-ink) 0%, var(--navy-ink) 27%, rgba(11, 26, 46, 0.72) 46%,
      rgba(11, 26, 46, 0.22) 68%, rgba(11, 26, 46, 0.04) 100%
    );
  }
  .chero__inner { position: relative; z-index: 1; width: 100%; max-width: var(--max); margin: 0 auto; }

  .chero__crumb { display: flex; align-items: center; gap: 10px; font-size: 12px; letter-spacing: 0.08em; color: var(--white-70); }
  .chero__crumb a { color: var(--white-70); text-decoration: none; transition: color var(--t-fast); }
  .chero__crumb a:hover { color: var(--gold-light); }
  .chero__crumb-sep { color: var(--white-30); }
  .chero__crumb [aria-current] { color: var(--gold-light); }

  .chero__title { font-family: var(--font-serif); font-weight: 500; font-size: clamp(38px, 5vw, 62px); line-height: 1.03; letter-spacing: -0.015em; margin: 16px 0 0; color: var(--cream); }
  .chero__line { margin-top: 22px; }
  .chero__lede { margin: 22px 0 0; max-width: 46ch; font-size: clamp(15px, 1.3vw, 17px); line-height: 1.6; color: var(--white-90); }

  /* ---------- Catalog ---------- */
  .catalog { background: var(--cream); padding: 0 var(--gutter) clamp(72px, 9vw, 128px); }

  .cfilters {
    position: relative; z-index: 5; margin-top: clamp(-56px, -5vw, -40px);
    background: var(--cream-soft); border: 1px solid var(--hairline-gold); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: clamp(22px, 2.4vw, 30px) clamp(22px, 2.6vw, 36px);
    display: grid; grid-template-columns: 1.05fr 1fr 0.92fr; gap: clamp(20px, 2.2vw, 38px);
  }
  .cfcol { display: flex; flex-direction: column; gap: clamp(16px, 1.8vw, 24px); }
  .cfcol--div { padding-left: clamp(20px, 2.2vw, 38px); border-left: 1px solid var(--hairline-gold); }
  .cfcol--meta { align-items: flex-end; justify-content: center; gap: clamp(14px, 1.6vw, 20px); }

  .cfgroup { display: flex; flex-direction: column; gap: 11px; }
  .cflabel { display: inline-flex; align-items: center; gap: 7px; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold-deep); font-weight: 500; }
  .cflabel :global(.icon) { color: var(--gold); }
  .cfpills { display: flex; flex-wrap: wrap; gap: 8px; }

  .chip {
    font-family: var(--font-sans); font-size: 12.5px; letter-spacing: 0.01em; color: var(--ink-60);
    padding: 8px 15px; border: 1px solid var(--ink-20); border-radius: 100px; background: transparent; cursor: pointer;
    transition: color var(--t-fast), border-color var(--t-fast), background var(--t-fast);
  }
  .chip:hover { border-color: var(--gold); color: var(--gold-deep); background: rgba(184, 153, 104, 0.07); }
  .chip.is-active { background: var(--navy); color: var(--cream); border-color: var(--navy); }
  .chip.is-active:hover { background: var(--navy); color: var(--cream); }

  .cfcount { margin: 0; font-size: 13px; color: var(--ink-60); letter-spacing: 0.02em; text-align: right; }
  .cfcount__n { font-family: var(--font-serif); font-size: 21px; color: var(--gold-deep); font-weight: 500; margin-right: 2px; }

  .cfsort { display: flex; flex-direction: column; gap: 8px; align-items: flex-end; }
  .cfsort__lab { font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold-deep); font-weight: 500; }
  .cfsort__field { position: relative; display: inline-flex; align-items: center; }
  .cfsort__field select {
    appearance: none; -webkit-appearance: none; font-family: var(--font-sans); font-size: 13px; color: var(--ink);
    background: transparent; border: 1px solid var(--ink-20); border-radius: 100px; padding: 9px 38px 9px 16px; cursor: pointer;
    transition: border-color var(--t-fast);
  }
  .cfsort__field select:hover { border-color: var(--gold); }
  .cfsort__field select:focus-visible { outline: none; border-color: var(--gold); box-shadow: var(--ring); }
  .cfsort__field :global(.icon) { position: absolute; right: 14px; color: var(--gold-deep); pointer-events: none; }

  .cgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(20px, 2vw, 32px); margin-top: clamp(34px, 4vw, 54px); }
  .cgrid__cell.is-hidden { display: none; }
  .cgrid__empty { margin-top: 28px; color: var(--ink-60); font-size: 15px; }

  /* ---------- Responsive ---------- */
  @media (max-width: 1080px) {
    .cfilters { grid-template-columns: 1fr 1fr; }
    .cfcol--meta {
      grid-column: 1 / -1; flex-direction: row; align-items: center; justify-content: space-between;
      border-left: 0; padding-left: 0; padding-top: clamp(16px, 2vw, 20px); border-top: 1px solid var(--hairline-gold);
    }
    .cgrid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .chero__img { width: 100%; }
    .chero__grad {
      background: linear-gradient(to right, var(--navy-ink) 0%, rgba(11, 26, 46, 0.8) 54%, rgba(11, 26, 46, 0.64) 100%);
    }
    .cfilters { display: none; }
    .cfbar-mobile {
      display: flex; flex-direction: column; gap: clamp(12px, 2vw, 16px); padding: clamp(16px, 2.4vw, 24px);
      margin-top: clamp(-48px, -4vw, -36px);
      background: var(--cream-soft); border: 1px solid var(--hairline-gold); border-radius: var(--radius-lg);
      box-shadow: var(--shadow-card);
    }
    .cfbar-group {
      display: flex; flex-direction: column; gap: clamp(10px, 1.6vw, 14px);
      padding: clamp(14px, 2vw, 18px); background: rgba(11, 26, 46, 0.5);
      border: 1px solid rgba(212, 187, 133, 0.28); border-radius: clamp(12px, 2vw, 16px);
    }
    .cfbar-label {
      display: inline-flex; align-items: center; gap: 10px; font-size: 10px; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--gold-light); font-weight: 500;
    }
    .cfbar-label :global(.icon) {
      width: clamp(36px, 7vw, 44px); height: clamp(36px, 7vw, 44px);
      border: 1px solid rgba(212, 187, 133, 0.32); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--gold-light); flex-shrink: 0;
    }
    .cfbar-select {
      font-family: var(--font-sans); font-size: clamp(13px, 1.5vw, 15px); color: var(--cream);
      background: transparent; border: none; cursor: pointer; appearance: none; -webkit-appearance: none;
      width: 100%; padding: 0; text-align: left; background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23D4BB85' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
      background-repeat: no-repeat; background-position: right 0 center; background-size: 16px; padding-right: 20px;
    }
    .cfbar-select:hover { }
    .cfbar-select:focus-visible { outline: none; }
    .cfbar-select option { background: var(--navy-ink); color: var(--cream); }
    .cfbar-filter {
      display: flex; width: 100%; padding: clamp(12px, 2vw, 16px);
      border: 2px dashed rgba(212, 187, 133, 0.48); border-radius: clamp(12px, 2vw, 16px);
      background: transparent; cursor: pointer; align-items: center; justify-content: center;
      gap: 8px; color: var(--gold-light); font-size: 11px; letter-spacing: 0.08em;
      text-transform: uppercase; font-weight: 500; transition: border-color var(--t-fast), background var(--t-fast);
    }
    .cfbar-filter:hover { border-color: var(--gold-light); background: rgba(212, 187, 133, 0.08); }
    .cmeta-mobile {
      display: flex; flex-direction: column; gap: clamp(12px, 2vw, 16px); padding: clamp(14px, 2vw, 18px) 0;
      border-top: 1px solid rgba(212, 187, 133, 0.2); margin-top: clamp(12px, 2vw, 16px);
    }
    .cmeta__count { margin: 0; font-size: 12px; color: var(--ink-60); display: flex; align-items: center; gap: 6px; }
    .cmeta__count b { font-family: var(--font-serif); font-size: 16px; color: var(--gold-deep); font-weight: 500; }
    .cmeta__sort { display: flex; align-items: center; gap: clamp(8px, 1.4vw, 12px); font-size: 12px; color: var(--ink-60); }
    .cmeta__sort select {
      appearance: none; -webkit-appearance: none; font-family: var(--font-sans); font-size: 12px;
      color: var(--cream); background: rgba(11, 26, 46, 0.5); border: 1px solid rgba(212, 187, 133, 0.28);
      border-radius: 6px; padding: clamp(8px, 1.4vw, 10px) clamp(20px, 2.4vw, 26px) clamp(8px, 1.4vw, 10px) clamp(10px, 1.8vw, 12px);
      cursor: pointer; background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23D4BB85' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
      background-repeat: no-repeat; background-position: right 8px center; background-size: 14px;
    }
    .cmeta__sort select:hover { border-color: var(--gold-light); background-color: rgba(11, 26, 46, 0.65); }
    .cmeta__sort select:focus-visible { outline: none; border-color: var(--gold-light); }
    .cgrid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const root = document.querySelector('[data-filters]');
  const grid = document.querySelector('[data-grid]');
  const countN = document.querySelector('[data-count]');
  const countWord = document.querySelector('[data-count-word]');
  const empty = document.querySelector('[data-empty]');
  const sortSel = document.querySelector<HTMLSelectElement>('[data-sort]');

  if (root && grid) {
    const cells = Array.from(grid.querySelectorAll<HTMLElement>('.cgrid__cell'));
    const state: Record<string, string> = { zona: 'all', tipo: 'all', preco: 'all', quartos: 'all' };

    const okPreco = (cell: HTMLElement) => {
      if (state.preco === 'all') return true;
      if (!cell.dataset.price) return false; // "Sob consulta" excluded from price bounds
      const price = Number(cell.dataset.price);
      const [lo, hi] = state.preco.split('-');
      if (lo && price < Number(lo)) return false;
      if (hi && price > Number(hi)) return false;
      return true;
    };

    const apply = () => {
      let visible = 0;
      cells.forEach((cell) => {
        const okZona = state.zona === 'all' || cell.dataset.zona === state.zona;
        const okTipo = state.tipo === 'all' || cell.dataset.cat === state.tipo;
        const okQuartos = state.quartos === 'all' || Number(cell.dataset.beds || 0) >= Number(state.quartos);
        const show = okZona && okTipo && okPreco(cell) && okQuartos;
        cell.classList.toggle('is-hidden', !show);
        if (show) visible++;
      });
      if (countN) countN.textContent = String(visible);
      if (countWord) countWord.textContent = visible === 1 ? 'imóvel' : 'imóveis';
      if (empty) (empty as HTMLElement).hidden = visible !== 0;
    };

    const sortCells = () => {
      const mode = sortSel?.value || 'recentes';
      const ordered = [...cells].sort((a, b) => {
        const pa = Number(a.dataset.price || 0), pb = Number(b.dataset.price || 0);
        const aa = Number(a.dataset.area || 0), ab = Number(b.dataset.area || 0);
        const oa = Number(a.dataset.order || 0), ob = Number(b.dataset.order || 0);
        switch (mode) {
          case 'preco-desc': return pb - pa;
          case 'preco-asc': return pa - pb;
          case 'area-desc': return ab - aa;
          default: return oa - ob; // "recentes" → original catalog order
        }
      });
      ordered.forEach((c) => grid.appendChild(c));
    };

    const setActive = (group: string, value: string) => {
      state[group] = value;
      root.querySelectorAll<HTMLElement>(`[data-group="${group}"]`).forEach((btn) => {
        const on = btn.dataset.value === value;
        btn.classList.toggle('is-active', on);
        btn.setAttribute('aria-pressed', String(on));
      });
      apply();
    };

    root.querySelectorAll<HTMLElement>('.chip').forEach((btn) => {
      btn.addEventListener('click', () => setActive(btn.dataset.group!, btn.dataset.value!));
    });

    sortSel?.addEventListener('change', sortCells);

    document.querySelector('[data-reset]')?.addEventListener('click', () => {
      (['zona', 'tipo', 'preco', 'quartos'] as const).forEach((g) => setActive(g, 'all'));
      if (sortSel) { sortSel.value = 'recentes'; sortCells(); }
    });

    // Pre-filter from query params (links from the homepage section / Zonas).
    const params = new URLSearchParams(location.search);
    const hasChip = (g: string, v: string) => !!root.querySelector(`[data-group="${g}"][data-value="${v}"]`);
    const paramToGroup: Record<string, string> = { zona: 'zona', tipo: 'tipo', preco: 'preco', quartos: 'quartos' };
    let applied = false;
    Object.entries(paramToGroup).forEach(([param, group]) => {
      const v = params.get(param);
      if (v && hasChip(group, v)) { setActive(group, v); applied = true; }
    });
    if (!applied) apply();
  }
</script>
