---
import Base from '../../layouts/Base.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';
import { properties, formatPrice, statusLabel } from '../../data/properties';
import { site } from '../../data/site';

export function getStaticPaths() {
  return properties.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}
const { p } = Astro.props;

// Gallery — PLACEHOLDER photography. Real per-property photo sets don't exist yet;
// most listings have ONE fitting placeholder (`p.image`) and fall back to a small
// generic interior pool. Listings with a real photo set provide `p.gallery`, which
// takes precedence so the page shows that coherent set instead of the pool.
// TODO(listings): replace with real, authorised photo sets per property.
const photoPool = [
  '/images/imoveis/imovel-sala-vista-rio.webp',
  '/images/imoveis/imovel-moradia-jardim-moderna.webp',
];
const gallery = p.gallery && p.gallery.length
  ? [p.image, ...p.gallery.filter((src) => src !== p.image)]
  : [p.image, ...photoPool.filter((src) => src !== p.image)];

const regionLabel = p.region ?? 'Porto';

// Spec cards (Tipologia, Quartos, Casas de banho, Área, Ano, Classe energética).
// Classe energética is legally required on PT listings, so it is shown here; the
// letters in properties.ts (`energy`) are placeholders until real certificates exist.
const specs = [
  { icon: 'building', label: 'Tipologia', value: p.type },
  { icon: 'bed', label: 'Quartos', value: String(p.beds) },
  { icon: 'bath', label: 'Casas de banho', value: String(p.baths) },
  { icon: 'ruler', label: 'Área', value: `${p.area} m²` },
  { icon: 'clock', label: 'Ano', value: String(p.year) },
  { icon: 'bolt', label: 'Classe energética', value: p.energy },
];

const related = [
  ...properties.filter((x) => x.slug !== p.slug && x.neighborhood === p.neighborhood),
  ...properties.filter((x) => x.slug !== p.slug && x.neighborhood !== p.neighborhood && x.featured),
].slice(0, 3);

const pill = p.status !== 'disponivel' ? statusLabel[p.status] : p.badge;
---
<Base title={p.title} description={p.blurb} image={p.image}>
  <article class="pd">
    <!-- Mobile navbar -->
    <div class="pd__mobile-nav" data-mobile-nav>
      <button class="pd__mobile-back" aria-label="Voltar">
        <Icon name="arrow" size={20} stroke={1.8} />
      </button>
      <div class="pd__mobile-logo">
        <img src={site.logo} alt={site.name} width="2587" height="386" />
      </div>
      <button class="pd__mobile-menu" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="3" y1="6" x2="17" y2="6"></line>
          <line x1="3" y1="10" x2="17" y2="10"></line>
          <line x1="3" y1="14" x2="17" y2="14"></line>
        </svg>
      </button>
    </div>

    <div class="container">
      <a class="pd__back" href="/imoveis"><span aria-hidden="true">←</span> Voltar aos imóveis</a>
    </div>

    <div class="container pd__layout">
      <div class="pd__main">
        <!-- Gallery -->
        <div class="pd__gallery" data-reveal data-gallery>
          <div class="pd__stage">
            <button type="button" class="pd__stage-btn" data-gallery-open aria-label="Ver fotografias em ecrã inteiro">
              <img src={gallery[0]} alt={`${p.title} — ${p.neighborhoodName}, ${regionLabel}`} data-gallery-main
                   width="1600" height="1067" fetchpriority="high" decoding="async" />
            </button>
            <span class="pd__count" aria-hidden="true">
              <Icon name="camera" size={14} stroke={1.6} /> <b data-gallery-current>1</b> / {gallery.length}
            </span>
            <div class="pd__actions">
              <button type="button" class="pd__circ" data-gallery-share aria-label="Partilhar imóvel">
                <Icon name="send" size={16} stroke={1.6} />
              </button>
              <button type="button" class="pd__circ" data-fav-toggle data-slug={p.slug} aria-pressed="false"
                      aria-label={`Guardar ${p.title} nos favoritos`}>
                <Icon name="heart" size={17} stroke={1.7} />
              </button>
            </div>
            {pill && <span class:list={['pd__statustag', `is-${p.status}`]}>{pill}</span>}
          </div>

          <div class="pd__thumbs" data-gallery-rail>
            {gallery.map((src, i) => (
              <button type="button" class:list={['pd__thumb', { 'is-active': i === 0 }]}
                      data-gallery-thumb data-index={i} aria-label={`Ver fotografia ${i + 1}`}>
                <img src={src} alt="" loading="lazy" decoding="async" width="240" height="170" />
              </button>
            ))}
            <button type="button" class="pd__thumb pd__thumb--all" data-gallery-open aria-label="Ver todas as fotografias">
              <span class="pd__thumb-ic" aria-hidden="true"><Icon name="camera" size={18} stroke={1.6} /></span>
              <span class="pd__thumb-allt">Ver todas</span>
              <span class="pd__thumb-alln">{gallery.length} fotos</span>
            </button>
          </div>
        </div>

        <!-- Info -->
        <div class="pd__info" data-reveal>
          <div class="pd__info-top">
            <span class="pd__hood">{p.neighborhoodName} · {regionLabel}</span>
            <span class="pd__meta">
              <span class="pd__ref">Ref. {p.ref}</span>
              {pill && <span class:list={['pd__badge', `is-${p.status}`]}>{pill}</span>}
            </span>
          </div>
          <h1 class="h1 pd__title">{p.title}</h1>
          <p class="pd__price">{formatPrice(p.price)}</p>
        </div>

        <!-- Characteristics -->
        <ul class="pd__specs" data-reveal>
          {specs.map((s) => (
            <li>
              <span class="pd__spec-ic" aria-hidden="true"><Icon name={s.icon} size={20} stroke={1.5} /></span>
              <span class="pd__spec-lbl">{s.label}</span>
              <span class="pd__spec-val">{s.value}</span>
            </li>
          ))}
        </ul>

        <!-- Description -->
        <div class="pd__desc" data-reveal>
          {p.description.map((para) => <p>{para}</p>)}
        </div>

        <!-- Mobile CTA buttons -->
        <div class="pd__mobile-ctas" data-reveal>
          <Button href={`/contacto?imovel=${p.ref}`} variant="gold" class="pd__cta-primary">
            <Icon name="clock" size={16} stroke={1.6} />
            Agendar visita
          </Button>
          <a href={site.phoneHref} class="pd__cta-secondary">
            <Icon name="users" size={16} stroke={1.6} />
            Falar com consultor
          </a>
        </div>

        <!-- Tagline footer -->
        <div class="pd__tagline" data-reveal>
          <Icon name="shield" size={20} stroke={1.4} />
          <span>Exclusividade que transforma heranças em oportunidades únicas.</span>
        </div>

        <!-- Highlights -->
        {p.features.length > 0 && (
          <div class="pd__highlights" data-reveal>
            <h2 class="pd__sec-title">Destaques</h2>
            <ul>
              {p.features.map((f) => (
                <li><span class="pd__feat-ic" aria-hidden="true"><Icon name="check" size={13} stroke={2} /></span>{f}</li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <!-- Sidebar contact card -->
      <aside class="pd__aside">
        <div class="pd__cta" data-reveal>
          <span class="pd__cta-eyebrow">Interessado neste imóvel?</span>
          <p class="pd__cta-price">{formatPrice(p.price)}</p>
          <Button href={`/contacto?imovel=${p.ref}`} variant="gold" arrow class="pd__cta-btn">Agendar visita</Button>
          <a class="pd__cta-phone" href={site.phoneHref}>
            <Icon name="phone" size={16} stroke={1.6} /> {site.phone}
          </a>
          <span class="pd__cta-sep" aria-hidden="true"></span>
          <ul class="pd__cta-meta">
            <li><Icon name="shield-check" size={15} stroke={1.6} /> Acompanhamento dedicado</li>
            <li><Icon name="clock" size={15} stroke={1.6} /> Resposta em 24h</li>
          </ul>
          <span class="pd__cta-art" aria-hidden="true"><Icon name="building" size={120} stroke={1} /></span>
          <span class="pd__cta-sign">{site.name}</span>
        </div>
      </aside>
    </div>

    {related.length > 0 && (
      <div class="container pd__related">
        <h2 class="h2 pd__related-title" data-reveal>Também na coleção</h2>
        <div class="pd__related-grid">
          {related.map((r) => <PropertyCard property={r} />)}
        </div>
      </div>
    )}
  </article>

  <!-- Lightbox -->
  <div class="pd__lb" data-lightbox hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="Galeria de fotografias">
    <button type="button" class="pd__lb-close" data-lightbox-close aria-label="Fechar galeria"><Icon name="close" size={20} stroke={1.8} /></button>
    <button type="button" class="pd__lb-nav pd__lb-prev" data-lightbox-prev aria-label="Fotografia anterior"><Icon name="arrow" size={20} stroke={1.8} /></button>
    <figure class="pd__lb-fig">
      <img src={gallery[0]} alt={`${p.title} — ${p.neighborhoodName}, ${regionLabel}`} data-lightbox-img />
      <figcaption class="pd__lb-cap" aria-hidden="true"><b data-lightbox-current>1</b> / {gallery.length}</figcaption>
    </figure>
    <button type="button" class="pd__lb-nav pd__lb-next" data-lightbox-next aria-label="Fotografia seguinte"><Icon name="arrow" size={20} stroke={1.8} /></button>
  </div>
</Base>

<style>
  .pd { background: var(--cream); padding: calc(var(--nav-h) + clamp(20px, 3vw, 36px)) 0 clamp(70px, 9vw, 120px); }

  .pd__back {
    display: inline-flex; align-items: center; gap: 9px; text-decoration: none; color: var(--ink-60);
    font-size: 13px; letter-spacing: 0.05em; transition: color var(--t-fast);
  }
  .pd__back span { color: var(--gold-deep); transition: transform var(--t-fast); }
  .pd__back:hover { color: var(--gold-deep); }
  .pd__back:hover span { transform: translateX(-3px); }

  /* ---------- Layout ---------- */
  .pd__layout {
    margin-top: clamp(20px, 2.4vw, 32px); display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(320px, 27vw, 380px);
    gap: clamp(30px, 4vw, 60px); align-items: start;
  }

  /* ---------- Gallery ---------- */
  .pd__stage {
    position: relative; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-card);
    background: var(--navy-soft);
  }
  .pd__stage-btn { display: block; width: 100%; padding: 0; margin: 0; border: 0; background: none; cursor: zoom-in; }
  .pd__stage-btn img {
    display: block; width: 100%; height: clamp(360px, 42vw, 520px); object-fit: cover;
    transition: transform var(--t-slow) var(--t-ease-emph);
  }
  .pd__stage-btn:hover img { transform: scale(1.02); }

  .pd__count {
    position: absolute; top: 16px; left: 16px; z-index: 2; display: inline-flex; align-items: center; gap: 7px;
    padding: 7px 13px; border-radius: 100px; color: var(--cream); font-size: 12.5px; letter-spacing: 0.03em;
    background: rgba(11, 26, 46, 0.6); -webkit-backdrop-filter: blur(7px); backdrop-filter: blur(7px);
  }
  .pd__count :global(.icon) { color: var(--gold-light); }
  .pd__count b { font-weight: 600; }

  .pd__actions { position: absolute; top: 14px; right: 14px; z-index: 3; display: flex; gap: 10px; }
  .pd__circ {
    width: 42px; height: 42px; border-radius: 50%; display: grid; place-items: center; cursor: pointer;
    color: var(--navy); background: rgba(255, 255, 255, 0.85); border: 1px solid rgba(255, 255, 255, 0.55);
    -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px); box-shadow: 0 2px 10px rgba(11, 26, 46, 0.16);
    transition: background var(--t-fast), color var(--t-fast), transform var(--t-fast), border-color var(--t-fast);
  }
  .pd__circ:hover { background: #fff; transform: scale(1.07); }
  .pd__circ[aria-pressed="true"] { background: var(--gold); color: var(--navy-ink); border-color: var(--gold); }
  .pd__circ[aria-pressed="true"] :global(.icon) { fill: var(--navy-ink); }

  .pd__statustag {
    position: absolute; bottom: 16px; left: 16px; z-index: 2; font-size: 10px; letter-spacing: 0.16em;
    text-transform: uppercase; font-weight: 500; padding: 7px 13px; border-radius: 3px; color: var(--cream);
    background: rgba(11, 26, 46, 0.78); -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
  }
  .pd__statustag.is-reservado { background: rgba(154, 126, 80, 0.95); color: var(--navy-ink); }
  .pd__statustag.is-vendido { background: rgba(11, 26, 46, 0.9); color: var(--white-70); }

  .pd__thumbs { display: flex; gap: 10px; margin-top: 12px; }
  .pd__thumb {
    flex: 1 1 0; min-width: 0; height: clamp(64px, 6.6vw, 84px); border-radius: var(--radius); overflow: hidden;
    padding: 0; border: 1px solid var(--hairline-gold); background: var(--navy-soft); cursor: pointer; position: relative;
    transition: border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast);
  }
  .pd__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; opacity: 0.72; transition: opacity var(--t-fast); }
  .pd__thumb:hover img { opacity: 1; }
  .pd__thumb:hover { transform: translateY(-2px); }
  .pd__thumb.is-active { border-color: var(--navy); box-shadow: 0 0 0 2px var(--navy); }
  .pd__thumb.is-active img { opacity: 1; }

  .pd__thumb--all {
    background: var(--navy-ink); border-color: var(--navy-ink); color: var(--cream);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; line-height: 1.2;
  }
  .pd__thumb--all:hover { background: var(--navy); transform: translateY(-2px); }
  .pd__thumb-ic { color: var(--gold-light); }
  .pd__thumb-allt { font-size: 11px; letter-spacing: 0.06em; }
  .pd__thumb-alln { font-size: 10px; color: var(--white-70); letter-spacing: 0.04em; }

  /* ---------- Info ---------- */
  .pd__info { margin-top: clamp(26px, 3vw, 38px); }
  .pd__info-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .pd__hood { font-size: 11.5px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold-deep); font-weight: 500; }
  .pd__meta { display: inline-flex; align-items: center; gap: 12px; }
  .pd__ref { font-size: 12px; color: var(--ink-40); letter-spacing: 0.06em; }
  .pd__badge {
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; color: var(--navy-ink);
    background: var(--gold-light); padding: 5px 11px; border-radius: 100px;
  }
  .pd__badge.is-reservado { background: var(--gold-deep); color: var(--cream); }
  .pd__badge.is-vendido { background: var(--navy); color: var(--white-70); }
  .pd__title { margin-top: 11px; }
  .pd__price { font-family: var(--font-serif); font-size: clamp(26px, 2.6vw, 34px); color: var(--gold-deep); font-weight: 500; margin: 10px 0 0; letter-spacing: -0.01em; }

  /* ---------- Characteristics ---------- */
  .pd__specs {
    list-style: none; margin: clamp(26px, 3vw, 38px) 0 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
  }
  .pd__specs li {
    background: var(--cream-soft); border: 1px solid var(--hairline-gold); border-radius: var(--radius);
    padding: clamp(15px, 1.4vw, 20px); display: flex; flex-direction: column; gap: 7px;
  }
  .pd__spec-ic { color: var(--gold-deep); }
  .pd__spec-lbl { font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-40); }
  .pd__spec-val { font-family: var(--font-serif); font-size: clamp(18px, 1.6vw, 22px); font-weight: 500; color: var(--navy); }

  /* ---------- Description ---------- */
  .pd__desc { margin-top: clamp(26px, 3vw, 38px); }
  .pd__desc p { font-size: 16.5px; line-height: 1.8; color: var(--ink-60); margin: 0 0 16px; max-width: 64ch; }
  .pd__desc p:last-child { margin-bottom: 0; }

  /* ---------- Highlights ---------- */
  .pd__highlights { margin-top: clamp(28px, 3vw, 40px); padding-top: clamp(26px, 3vw, 34px); border-top: 1px solid var(--ink-10); }
  .pd__sec-title { font-family: var(--font-serif); font-size: clamp(20px, 2vw, 24px); color: var(--navy); font-weight: 500; }
  .pd__highlights ul { list-style: none; margin: 18px 0 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 13px 28px; }
  .pd__highlights li { display: flex; align-items: flex-start; gap: 11px; font-size: 15px; color: var(--ink); }
  .pd__feat-ic {
    flex-shrink: 0; width: 22px; height: 22px; display: grid; place-items: center; border-radius: 50%;
    background: rgba(184, 153, 104, 0.16); color: var(--gold-deep); margin-top: 1px;
  }

  /* ---------- Sidebar CTA ---------- */
  .pd__cta {
    position: sticky; top: calc(var(--nav-h) + 22px); overflow: hidden;
    background: var(--cream-soft); border: 1px solid var(--hairline-gold-strong); border-radius: var(--radius-lg);
    padding: clamp(26px, 2vw, 32px); box-shadow: var(--shadow-card);
  }
  .pd__cta-eyebrow { font-size: 11.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-deep); font-weight: 600; position: relative; }
  .pd__cta-price { font-family: var(--font-serif); font-size: clamp(28px, 2.4vw, 34px); color: var(--navy); margin: 11px 0 22px; font-weight: 500; position: relative; }
  :global(.pd__cta-btn) { width: 100%; justify-content: center; }
  .pd__cta-phone {
    display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 12px; padding: 14px;
    text-decoration: none; color: var(--navy); font-size: 14px; letter-spacing: 0.03em; position: relative;
    border: 1px solid var(--ink-20); border-radius: var(--radius-sm); transition: border-color var(--t-fast), color var(--t-fast);
  }
  .pd__cta-phone:hover { border-color: var(--gold); color: var(--gold-deep); }
  .pd__cta-phone :global(.icon) { color: var(--gold-deep); }
  .pd__cta-sep { display: block; height: 1px; background: var(--ink-10); margin: 22px 0; position: relative; }
  .pd__cta-meta { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; position: relative; }
  .pd__cta-meta li { display: flex; align-items: center; gap: 11px; font-size: 13px; color: var(--ink-60); }
  .pd__cta-meta :global(.icon) { color: var(--gold-deep); flex-shrink: 0; }
  .pd__cta-art { position: absolute; right: -26px; bottom: -22px; color: var(--gold); opacity: 0.07; pointer-events: none; }
  .pd__cta-sign {
    display: block; margin-top: 24px; font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-40); position: relative;
  }

  /* ---------- Related ---------- */
  .pd__related { margin-top: clamp(56px, 7vw, 96px); padding-top: clamp(46px, 6vw, 78px); border-top: 1px solid var(--ink-10); }
  .pd__related-title { margin-bottom: clamp(26px, 3vw, 40px); }
  .pd__related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(18px, 2vw, 30px); }

  /* ---------- Lightbox ---------- */
  .pd__lb {
    position: fixed; inset: 0; z-index: 2000; display: flex; align-items: center; justify-content: center;
    gap: clamp(8px, 2vw, 24px); padding: clamp(16px, 4vw, 48px);
    background: rgba(8, 17, 30, 0.95); -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
  }
  .pd__lb[hidden] { display: none; }
  .pd__lb-fig { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 16px; max-width: min(1100px, 90vw); }
  .pd__lb-fig img { max-width: 100%; max-height: 80vh; object-fit: contain; border-radius: var(--radius); box-shadow: var(--shadow-float); }
  .pd__lb-cap { font-family: var(--font-serif); font-size: 15px; color: var(--white-70); letter-spacing: 0.08em; }
  .pd__lb-cap b { color: var(--gold-light); font-weight: 500; }
  .pd__lb-close { position: absolute; top: clamp(14px, 2vw, 26px); right: clamp(14px, 2vw, 26px); }
  .pd__lb-close, .pd__lb-nav {
    width: 50px; height: 50px; border-radius: 50%; display: grid; place-items: center; cursor: pointer; flex-shrink: 0;
    color: var(--cream); background: rgba(244, 237, 222, 0.1); border: 1px solid var(--hairline-light);
    transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
  }
  .pd__lb-close:hover, .pd__lb-nav:hover { background: var(--gold); color: var(--navy-ink); border-color: var(--gold); }
  .pd__lb-prev :global(.icon) { transform: rotate(180deg); }

  /* ---------- Responsive ---------- */
  .pd__mobile-nav { display: none; }

  @media (max-width: 960px) {
    .pd__layout { grid-template-columns: 1fr; gap: clamp(28px, 4vw, 40px); }
    .pd__cta { position: static; }
    .pd__related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 680px) {
    /* Mobile navbar */
    .pd__mobile-nav {
      display: flex; align-items: center; justify-content: space-between;
      position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 60px;
      background: linear-gradient(180deg, rgba(11, 26, 46, 0.92), rgba(11, 26, 46, 0.88));
      -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--hairline-gold);
      padding: 0 16px; gap: 16px;
    }
    .pd__mobile-back {
      width: 44px; height: 44px; display: grid; place-items: center; border-radius: 50%;
      background: rgba(244, 237, 222, 0.95); border: none; cursor: pointer; color: var(--navy);
      transition: all var(--t-fast);
    }
    .pd__mobile-back:active { transform: scale(0.95); }
    .pd__mobile-back :global(.icon) { transform: rotate(180deg); }

    .pd__mobile-logo {
      flex: 1; display: flex; align-items: center; justify-content: center;
      background: linear-gradient(180deg, rgba(16, 36, 61, 0.6), rgba(10, 23, 41, 0.6));
      border: 1px solid rgba(184, 153, 104, 0.25);
      border-radius: 999px;
      padding: 8px 20px;
      -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    }
    .pd__mobile-logo img { height: 22px; width: auto; }

    .pd__mobile-menu {
      width: 44px; height: 44px; display: grid; place-items: center; border-radius: 50%;
