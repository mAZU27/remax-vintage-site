  @media (prefers-reduced-motion: reduce) {
    .pd__stage-btn:hover img, .pd__thumb:hover, .pd__thumb--all:hover, .pd__circ:hover { transform: none; }
  }
</style>

<script>
  // Gallery: thumbnail → main image swap, share, and a fullscreen lightbox.
  // Favorites are NOT handled here — the heart reuses the shared `cv:favorites`
  // delegated handler that PropertyCard (related block) already mounts on the page.
  const galleryEl = document.querySelector<HTMLElement>('[data-gallery]');

  if (galleryEl) {
    const main = galleryEl.querySelector<HTMLImageElement>('[data-gallery-main]');
    const thumbs = Array.from(galleryEl.querySelectorAll<HTMLElement>('[data-gallery-thumb]'));
    const currentEl = galleryEl.querySelector<HTMLElement>('[data-gallery-current]');
    const srcs = thumbs.map((t) => t.querySelector('img')?.src || '');

    const lb = document.querySelector<HTMLElement>('[data-lightbox]');
    const lbImg = lb?.querySelector<HTMLImageElement>('[data-lightbox-img]') ?? null;
    const lbCur = lb?.querySelector<HTMLElement>('[data-lightbox-current]') ?? null;
    const closeBtn = lb?.querySelector<HTMLButtonElement>('[data-lightbox-close]') ?? null;

    let idx = 0;

    const refreshLb = () => {
      if (lb && !lb.hidden) {
        if (lbImg) lbImg.src = srcs[idx];
        if (lbCur) lbCur.textContent = String(idx + 1);
      }
    };

    const setActive = (i: number) => {
      idx = (i + srcs.length) % srcs.length;
      if (main) main.src = srcs[idx];
      thumbs.forEach((t, k) => t.classList.toggle('is-active', k === idx));
      if (currentEl) currentEl.textContent = String(idx + 1);
      refreshLb();
    };

    thumbs.forEach((t, i) => t.addEventListener('click', () => setActive(i)));

    // Share — native sheet where available, otherwise copy the link.
    const shareBtn = galleryEl.querySelector<HTMLButtonElement>('[data-gallery-share]');
    shareBtn?.addEventListener('click', async () => {
      const url = window.location.href;
      try {
        if (navigator.share) await navigator.share({ title: document.title, url });
        else if (navigator.clipboard) {
          await navigator.clipboard.writeText(url);
          const prev = shareBtn.getAttribute('aria-label');
          shareBtn.setAttribute('aria-label', 'Link copiado');
          setTimeout(() => prev && shareBtn.setAttribute('aria-label', prev), 1600);
        }
      } catch { /* user dismissed the share sheet */ }
    });

    // Lightbox
    const openLb = () => {
      if (!lb) return;
      lb.hidden = false;
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      refreshLb();
      closeBtn?.focus();
    };
    const closeLb = () => {
      if (!lb) return;
      lb.hidden = true;
      lb.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    galleryEl.querySelectorAll<HTMLElement>('[data-gallery-open]').forEach((b) => b.addEventListener('click', openLb));
    closeBtn?.addEventListener('click', closeLb);
    lb?.querySelector<HTMLButtonElement>('[data-lightbox-prev]')?.addEventListener('click', () => setActive(idx - 1));
    lb?.querySelector<HTMLButtonElement>('[data-lightbox-next]')?.addEventListener('click', () => setActive(idx + 1));
    lb?.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });

    document.addEventListener('keydown', (e) => {
      if (!lb || lb.hidden) return;
      if (e.key === 'Escape') closeLb();
      else if (e.key === 'ArrowLeft') setActive(idx - 1);
      else if (e.key === 'ArrowRight') setActive(idx + 1);
    });
  }
</script>
