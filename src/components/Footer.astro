---
import { site } from '../data/site';
import Icon from './Icon.astro';
import Crest from './Crest.astro';
import FinalBrand from './FinalBrand.astro';

const year = new Date().getFullYear();
---
<FinalBrand />

<footer class="foot" id="footer">
  <div class="container foot__bar">
    <a class="foot__brand" href="/" aria-label={`${site.name} — início`}>
      <Crest size={40} />
      <img class="foot__logo" src={site.logo} alt={site.name} width="2587" height="386" />
    </a>

    <span class="foot__place">Porto <span class="foot__sep" aria-hidden="true">·</span> Portugal</span>

    <div class="foot__social">
      {site.social.map((s) => (
        <a class="foot__social-link" href={s.href} aria-label={s.label} target="_blank" rel="noopener noreferrer">
          <Icon name={s.icon} size={16} stroke={1.6} />
        </a>
      ))}
    </div>
  </div>

  <div class="container foot__legal">
    <p class="foot__copy">
      © {year} {site.brandLine}.
      <!-- TODO(legal): inserir nº de licença AMI real antes do lançamento. -->
      Licença AMI 0000 · Cada agência é juridicamente independente.
    </p>
    <nav class="foot__links" aria-label="Legal">
      <a href="/privacidade">Política de Privacidade</a>
      <a href="/termos">Termos e Condições</a>
    </nav>
  </div>
</footer>

<style>
  .foot {
    position: relative; background: var(--navy-ink); color: var(--cream);
    border-top: 1px solid var(--hairline-gold);
    padding: clamp(26px, 3vw, 40px) 0 clamp(24px, 3vw, 34px);
  }

  /* ---- Top bar: brand · place · social ---- */
  .foot__bar {
    display: flex; align-items: center; justify-content: space-between; gap: clamp(20px, 3vw, 48px);
  }
  .foot__brand { display: inline-flex; align-items: center; gap: 16px; text-decoration: none; flex-shrink: 0; }
  .foot__logo { height: 30px; width: auto; }

  .foot__place {
    font-family: var(--font-sans); font-size: clamp(11px, 1vw, 13px); letter-spacing: 0.38em;
    text-transform: uppercase; color: var(--gold-light); white-space: nowrap;
  }
  .foot__sep { color: var(--gold); margin: 0 0.5em; }

  .foot__social { display: flex; gap: 10px; flex-shrink: 0; }
  .foot__social-link {
    display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px;
    border-radius: 50%; color: var(--gold-light);
    border: 1px solid var(--hairline-gold);
    background: rgba(244, 237, 222, 0.03);
    transition: color var(--t-fast), border-color var(--t-fast), background var(--t-fast), transform var(--t-fast);
  }
  .foot__social-link:hover {
    color: var(--navy-ink); background: var(--gold-light); border-color: var(--gold-light);
    transform: translateY(-2px);
  }

  /* ---- Legal row ---- */
  .foot__legal {
    margin-top: clamp(22px, 2.4vw, 32px); padding-top: clamp(20px, 2.2vw, 28px);
    border-top: 1px solid var(--hairline-light);
    display: flex; align-items: center; justify-content: space-between; gap: 16px 32px; flex-wrap: wrap;
  }
  .foot__copy { margin: 0; font-size: 12px; color: var(--white-30); letter-spacing: 0.02em; line-height: 1.6; }
  .foot__links { display: flex; gap: clamp(18px, 2vw, 30px); flex-shrink: 0; }
  .foot__links a {
    position: relative; font-size: 12px; letter-spacing: 0.03em; color: var(--white-50);
    text-decoration: none; transition: color var(--t-fast);
  }
  .foot__links a:hover { color: var(--gold-light); }

  /* ---- Responsive ---- */
  @media (max-width: 760px) {
    .foot__bar { flex-direction: column; align-items: center; text-align: center; gap: 22px; }
    .foot__legal { flex-direction: column; align-items: center; text-align: center; gap: 14px; }
  }
</style>
