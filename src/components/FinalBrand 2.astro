---
// Cinematic brand end-cap (Section B). Sits below the navigation footer as
// the final, signature moment of every page. Reveal is orchestrated from a
// single root: the global IntersectionObserver adds `.is-in` to `.fb`, and
// children cascade via per-element `--d`. The giant wordmark reveals with a
// left→right clip-path wipe + a single soft gold light pass + a settling
// bloom. Atmosphere (faint Porto image, gold marble veins, slow light sweep,
// grain) is CSS-only and fully neutralised under prefers-reduced-motion.
import Icon from './Icon.astro';
import Crest from './Crest.astro';
import { site, primaryCta } from '../data/site';

const year = new Date().getFullYear();
---
<section class="fb" data-reveal>
  <!-- Atmosphere (decorative) -->
  <div class="fb__porto" aria-hidden="true">
    <img src="/images/porto/porto-ribeira-barcos.webp" alt="" loading="lazy" decoding="async" width="1600" height="900" />
  </div>
  <div class="fb__veins" aria-hidden="true"></div>
  <div class="fb__glow" aria-hidden="true"></div>
  <div class="fb__sweep" aria-hidden="true"></div>
  <div class="fb__grain" aria-hidden="true"></div>

  <div class="container fb__inner">
    <div class="fb__eyebrow r" style="--d: 120ms">
      <span class="fb__place">Porto</span>
      <Crest size={42} />
      <span class="fb__place">Portugal</span>
    </div>

    <div class="fb__wordmark" role="img" aria-label="Collection Vintage">
      <span class="fb__sheen" aria-hidden="true"></span>
      <span class="fb__word fb__word--1">Collection</span>
      <span class="fb__word fb__word--2">Vintage</span>
    </div>

    <p class="fb__tagline r" style="--d: 700ms">Propriedades exclusivas <span>·</span> Valores intemporais</p>

    <div class="fb__cta-wrap r" style="--d: 840ms">
      <a class="fb__cta" href={primaryCta.href} aria-label={`${primaryCta.label} — o próximo passo`}>
        <span class="fb__cta-thumb">
          <img src="/images/imoveis/imovel-fachada-thumb.webp" alt="" loading="lazy" decoding="async" width="200" height="200" />
        </span>
        <span class="fb__cta-text">
          <span class="fb__cta-label">Pronto para o próximo passo?</span>
          <span class="fb__cta-title">{primaryCta.label}</span>
        </span>
        <span class="fb__cta-arrow" aria-hidden="true"><Icon name="arrow" size={20} stroke={1.8} /></span>
      </a>
    </div>
  </div>

  <p class="fb__legal">
    © {year} {site.brandLine}.
    <!-- TODO(legal): inserir nº de licença AMI real antes do lançamento. -->
    Licença AMI 0000 · Cada agência é juridicamente independente.
  </p>
</section>

<style>
  .fb {
    position: relative; isolation: isolate; overflow: hidden;
    background: linear-gradient(118deg, var(--navy-ink) 0%, #081019 58%, #0A1320 100%);
    color: var(--cream);
    padding: clamp(72px, 10vw, 150px) var(--gutter) clamp(58px, 6vw, 90px);
  }
  /* Section reveal — whole-section soft fade (children carry the rise/wipe). */
  .fb[data-reveal] { transform: none; transition: opacity 1.1s var(--t-ease-emph); }

  /* ---- Atmosphere ---- */
  .fb__porto { position: absolute; inset: 0; z-index: -3; opacity: 0.3; pointer-events: none; }
  .fb__porto img { width: 100%; height: 100%; object-fit: cover; object-position: left center; filter: saturate(0.72) brightness(0.62); }
  .fb__porto::after {
    content: ""; position: absolute; inset: 0;
    background:
      linear-gradient(90deg, transparent, rgba(8, 16, 25, 0.55) 48%, #081019 78%),
      linear-gradient(0deg, rgba(8, 16, 25, 0.85), transparent 55%);
  }
  .fb__veins {
    position: absolute; inset: 0; z-index: -2; opacity: 0.55; pointer-events: none;
    background:
      linear-gradient(116deg, transparent 60%, rgba(212, 187, 133, 0.22) 62.5%, transparent 64%),
      linear-gradient(122deg, transparent 71%, rgba(184, 153, 104, 0.16) 72.5%, transparent 74%),
      linear-gradient(112deg, transparent 80%, rgba(212, 187, 133, 0.12) 81.5%, transparent 83%),
      radial-gradient(42% 64% at 93% 26%, rgba(184, 153, 104, 0.1), transparent 62%);
  }
  .fb__glow {
    position: absolute; left: 50%; top: 44%; transform: translate(-50%, -50%);
    width: min(900px, 78%); height: 62%; z-index: -1; pointer-events: none;
    background: radial-gradient(closest-side, rgba(184, 153, 104, 0.2), transparent 72%);
    /* Almost-imperceptible ambient drift. */
    animation: fbGlowDrift 22s ease-in-out infinite alternate; will-change: transform, opacity;
  }
  @keyframes fbGlowDrift {
    from { transform: translate(-50%, -50%) scale(1); opacity: 0.82; }
    to { transform: translate(-50%, -53%) scale(1.08); opacity: 1; }
  }
  .fb__sweep {
    position: absolute; top: -25%; left: -40%; width: 46%; height: 150%; z-index: 0; pointer-events: none;
    background: linear-gradient(105deg, transparent, rgba(212, 187, 133, 0.1), transparent);
    transform: skewX(-13deg); opacity: 0;
    animation: fbSweep 11s ease-in-out 1.4s infinite; will-change: transform, opacity;
  }
  @keyframes fbSweep {
    0% { transform: translateX(0) skewX(-13deg); opacity: 0; }
    16% { opacity: 0.9; }
    62% { transform: translateX(300%) skewX(-13deg); opacity: 0.5; }
    100% { transform: translateX(360%) skewX(-13deg); opacity: 0; }
  }
  .fb__grain {
    position: absolute; inset: 0; z-index: 1; pointer-events: none; opacity: 0.35; mix-blend-mode: overlay;
    background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.1) 1px, transparent 0);
    background-size: 3px 3px;
  }

  .fb__inner { position: relative; z-index: 2; text-align: center; }

  /* ---- Reveal cascade ---- */
  .fb .r {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.95s var(--t-ease-emph), transform 0.95s var(--t-ease-emph);
    transition-delay: var(--d, 0ms); will-change: opacity, transform;
  }
  .fb.is-in .r { opacity: 1; transform: none; }

  /* ---- Eyebrow: PORTO · crest · PORTUGAL ---- */
  .fb__eyebrow { display: inline-flex; align-items: center; justify-content: center; gap: clamp(18px, 3vw, 40px); }
  .fb__place {
    font-family: var(--font-sans); font-size: clamp(11px, 1vw, 13px); letter-spacing: 0.42em;
    text-transform: uppercase; color: var(--gold-light); font-weight: 500;
  }
  .fb__place:first-child { padding-left: 0.42em; }

  /* ---- Giant wordmark ---- */
  .fb__wordmark { position: relative; display: block; margin: clamp(18px, 2.4vw, 34px) 0 0; }
  .fb__word {
    display: block; font-family: var(--font-serif); font-weight: 500;
    font-size: clamp(58px, 15.5vw, 248px); line-height: 0.9; letter-spacing: -0.018em;
    background: linear-gradient(180deg, var(--gold-light) 0%, var(--gold) 52%, var(--gold-deep) 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    /* Hidden before reveal: clipped from the right (wipes open left→right). */
    clip-path: inset(0 100% 0 0); transform: translateY(8px);
    will-change: clip-path, transform;
  }
  .fb__word--2 { margin-top: -0.04em; }
  @supports not ((-webkit-background-clip: text) or (background-clip: text)) {
    .fb__word { background: none; color: var(--gold-light); }
  }
  .fb.is-in .fb__word--1 { animation: fbWipe 1.15s var(--t-ease-emph) 0.18s both; }
  .fb.is-in .fb__word--2 { animation: fbWipe 1.15s var(--t-ease-emph) 0.42s both; }
  @keyframes fbWipe {
    from { clip-path: inset(0 100% 0 0); transform: translateY(8px); }
    to { clip-path: inset(0 0 0 0); transform: translateY(0); }
  }
  /* Settling glow bloom once the wordmark lands. */
  .fb.is-in .fb__wordmark { animation: fbBloom 2.4s var(--t-ease-emph) 1.2s 1 both; }
  @keyframes fbBloom {
    0% { filter: drop-shadow(0 0 0 rgba(212, 187, 133, 0)); }
    45% { filter: drop-shadow(0 14px 46px rgba(212, 187, 133, 0.32)); }
    100% { filter: drop-shadow(0 10px 30px rgba(212, 187, 133, 0.13)); }
  }
  /* Soft narrow light pass — clipped to the wordmark box. */
  .fb__sheen { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 2; }
  .fb.is-in .fb__sheen::before {
    content: ""; position: absolute; top: -10%; bottom: -10%; left: -60%; width: 36%;
    background: linear-gradient(105deg, transparent, rgba(255, 251, 240, 0.55), transparent);
    transform: skewX(-12deg); animation: fbTitleSheen 1.5s var(--t-ease-emph) 1.35s 1 forwards;
  }
  @keyframes fbTitleSheen { to { left: 122%; } }

  .fb__tagline {
    margin: clamp(20px, 2.4vw, 32px) 0 0; font-family: var(--font-sans);
    font-size: clamp(12px, 1.3vw, 16px); letter-spacing: 0.34em; text-transform: uppercase;
    color: var(--gold-light);
  }
  .fb__tagline span { color: var(--gold); margin: 0 0.4em; }

  /* ---- CTA panel ---- */
  .fb__cta-wrap { position: absolute; right: var(--gutter); bottom: clamp(48px, 7vw, 92px); z-index: 3; }
  .fb__cta {
    display: inline-flex; align-items: center; gap: clamp(14px, 1.4vw, 20px);
    padding: 13px 13px 13px 15px; border-radius: 80px; text-decoration: none;
    background: rgba(11, 26, 46, 0.5); border: 1px solid var(--hairline-gold);
    -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
    box-shadow: 0 30px 70px -42px rgba(0, 0, 0, 0.85);
    transition: transform var(--t-med), border-color var(--t-med), box-shadow var(--t-med), background var(--t-med);
  }
  .fb__cta:hover {
    transform: translateY(-4px); border-color: var(--gold-light); background: rgba(11, 26, 46, 0.66);
    box-shadow: 0 36px 80px -40px rgba(0, 0, 0, 0.9), 0 0 0 1px rgba(212, 187, 133, 0.22);
  }
  .fb__cta-thumb { width: 64px; height: 64px; border-radius: 14px; overflow: hidden; flex-shrink: 0; }
  .fb__cta-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--t-slow); }
  .fb.is-in .fb__cta-thumb img { animation: fbThumb 1.4s var(--t-ease-emph) 0.95s 1 both; }
  @keyframes fbThumb { from { transform: scale(1.14); } to { transform: scale(1); } }
  .fb__cta:hover .fb__cta-thumb img { transform: scale(1.06); }
  .fb__cta-text { display: flex; flex-direction: column; gap: 3px; text-align: left; padding-right: 6px; }
  .fb__cta-label { font-size: 10.5px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold-light); }
  .fb__cta-title { font-family: var(--font-serif); font-size: clamp(22px, 2vw, 27px); font-weight: 500; color: var(--cream); }
  .fb__cta-arrow {
    position: relative; width: 52px; height: 52px; border-radius: 50%; flex-shrink: 0;
    display: grid; place-items: center; color: var(--gold-light);
    border: 1px solid var(--hairline-gold-strong);
    transition: background var(--t-med), color var(--t-med), border-color var(--t-med);
  }
  .fb__cta-arrow :global(.arrow) { transition: transform var(--t-med); }
  .fb__cta:hover .fb__cta-arrow { background: var(--gold); color: var(--navy-ink); border-color: var(--gold); }
  .fb__cta:hover .fb__cta-arrow :global(.arrow) { transform: translateX(3px); }
  /* One soft glow ring on reveal. */
  .fb__cta-arrow::after {
    content: ""; position: absolute; inset: -1px; border-radius: 50%; border: 1px solid var(--gold-light); opacity: 0;
  }
  .fb.is-in .fb__cta-arrow::after { animation: fbRing 1.9s var(--t-ease-emph) 1.5s 1 both; }
  @keyframes fbRing {
    0% { opacity: 0.8; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.85); }
  }

  /* ---- Legal strip ---- */
  .fb__legal {
    position: relative; z-index: 2; margin: clamp(56px, 7vw, 96px) 0 0; text-align: center;
    font-size: 12px; color: var(--white-30); letter-spacing: 0.02em; line-height: 1.6;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1100px) {
    .fb__inner { display: flex; flex-direction: column; align-items: center; }
    .fb__cta-wrap { position: static; margin: clamp(36px, 6vw, 52px) auto 0; }
  }
  @media (max-width: 560px) {
    .fb__cta { width: 100%; max-width: 360px; }
    .fb__cta-title { font-size: 21px; }
    .fb__legal { margin-top: 48px; }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .fb__sweep { display: none; }
    .fb__glow { animation: none; }
    .fb__word { clip-path: none !important; transform: none !important; }
    .fb.is-in .fb__word--1,
    .fb.is-in .fb__word--2,
    .fb.is-in .fb__wordmark,
    .fb.is-in .fb__cta-thumb img { animation: none; }
    .fb.is-in .fb__sheen::before,
    .fb.is-in .fb__cta-arrow::after { animation: none; display: none; }
  }
</style>
