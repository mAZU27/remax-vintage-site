---
// Reusable metric strip with count-up on reveal. Server-renders the final
// value so it stays correct with no JS / under reduced motion.
import type { Metric } from '../data/carreiras';
interface Props {
  metrics: Metric[];
  tone?: 'navy' | 'cream';
}
const { metrics, tone = 'navy' } = Astro.props;
const display = (m: Metric) => `${m.prefix ?? ''}${m.value}${m.suffix ?? ''}`;
---
<ul class:list={['cmetrics', `cmetrics--${tone}`]}>
  {metrics.map((m, i) => (
    <li class="cmetrics__item" data-reveal style={`--reveal-delay:${i * 90}ms`}>
      <span
        class="cmetrics__value"
        data-count={m.value}
        data-prefix={m.prefix ?? ''}
        data-suffix={m.suffix ?? ''}
      >{display(m)}</span>
      <span class="cmetrics__label">{m.label}</span>
    </li>
  ))}
</ul>

<style>
  .cmetrics {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1px; border-radius: var(--radius); overflow: hidden;
  }
  .cmetrics--navy { background: var(--hairline-gold); border: 1px solid var(--hairline-gold); }
  .cmetrics--cream { background: var(--hairline-gold); border: 1px solid var(--hairline-gold); }
  .cmetrics__item {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 8px; padding: clamp(26px, 3.4vw, 40px) clamp(14px, 2vw, 26px);
  }
  .cmetrics--navy .cmetrics__item { background: var(--navy-ink); }
  .cmetrics--cream .cmetrics__item { background: var(--cream-soft); }
  .cmetrics__value {
    font-family: var(--font-serif); font-weight: 500; letter-spacing: -0.02em;
    font-size: clamp(34px, 4.4vw, 56px); line-height: 1; color: var(--gold-light);
    font-variant-numeric: tabular-nums;
  }
  .cmetrics--cream .cmetrics__value { color: var(--gold-deep); }
  .cmetrics__label {
    font-size: 12.5px; letter-spacing: 0.05em; font-weight: 500; margin-top: 4px;
    max-width: 16ch;
  }
  .cmetrics--navy .cmetrics__label { color: var(--white-70); }
  .cmetrics--cream .cmetrics__label { color: var(--ink-60); }

  @media (max-width: 720px) {
    .cmetrics { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  const nums = Array.from(
    document.querySelectorAll<HTMLElement>('.cmetrics__value[data-count]')
  );
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (nums.length && !reduce && 'IntersectionObserver' in window) {
    const run = (el: HTMLElement) => {
      const target = parseFloat(el.dataset.count || '0');
      const prefix = el.dataset.prefix || '';
      const suffix = el.dataset.suffix || '';
      const dur = 1400;
      const start = performance.now();
      const tick = (now: number) => {
        const p = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = prefix + Math.round(target * eased) + suffix;
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = prefix + target + suffix;
      };
      requestAnimationFrame(tick);
    };
    const io = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            run(e.target as HTMLElement);
            obs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.4 }
    );
    nums.forEach((n) => io.observe(n));
  }
</script>
