---
// Prova social da equipa — horizontal scroll carousel. Native scroll-snap
// drives a swipeable track (drag / wheel / arrow buttons); a gold line tracks
// progress so it's obvious there is more to the right. Progressive enhancement:
// without JS it is still a plain horizontal scroller. Voices live in carreiras.ts
// (flagged placeholders — replace with real, authorised testimonials).
import SectionEyebrow from './SectionEyebrow.astro';
import Button from './Button.astro';
import Icon from './Icon.astro';
import { careersTeam as t } from '../data/carreiras';
---
<section class="section section--navy on-navy cteam">
  <div class="container">
    <header class="shead shead--center">
      <SectionEyebrow text={t.eyebrow} center />
      <h2 class="h2 cteam__title" data-reveal style="--reveal-delay:80ms">
        {t.titleLead} <em class="em-gold serif-it">{t.titleEmphasis}</em>
      </h2>
      <p class="lede cteam__intro" data-reveal style="--reveal-delay:150ms">{t.intro}</p>
    </header>

    <div class="cteam__car" data-reveal data-team-car>
      <div class="cteam__viewport" data-team-viewport>
        <ul class="cteam__track">
          {t.voices.map((v) => (
            <li class="cvoice">
              <span class="cvoice__quote-ic" aria-hidden="true"><Icon name="quote" size={26} stroke={1.4} /></span>
              <p class="cvoice__quote">{v.quote}</p>
              <div class="cvoice__person">
                <span class="cvoice__avatar" aria-hidden="true">{v.initials}</span>
                <span class="cvoice__id">
                  <span class="cvoice__name">{v.name}</span>
                  <span class="cvoice__role">{v.role}</span>
                </span>
              </div>
              <ul class="cvoice__stats">
                {v.stats.map((s) => <li>{s}</li>)}
              </ul>
            </li>
          ))}
        </ul>
      </div>

      <div class="cteam__controls">
        <div class="cteam__progress" aria-hidden="true"><span data-team-bar></span></div>
        <div class="cteam__btns">
          <button type="button" class="cteam__btn cteam__btn--prev" data-team-prev aria-label="Testemunhos anteriores">
            <Icon name="arrow" size={16} stroke={1.8} />
          </button>
          <button type="button" class="cteam__btn" data-team-next aria-label="Mais testemunhos">
            <Icon name="arrow" size={16} stroke={1.8} />
          </button>
        </div>
      </div>
    </div>

    <div class="cteam__strip" data-reveal>
      <p class="cteam__strip-text">{t.strip.text}</p>
      <Button href={t.strip.cta.href} variant="gold" arrow>{t.strip.cta.label}</Button>
    </div>
  </div>
</section>

<style>
  .shead { margin-bottom: clamp(40px, 4vw, 64px); }
  .shead--center { text-align: center; }
  .cteam__title { margin-top: 16px; margin-inline: auto; }
  .cteam__intro { margin: 16px auto 0; }

  /* ---------- Carousel ---------- */
  .cteam__viewport {
    overflow-x: auto; overflow-y: hidden;
    scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none;
    padding-block: 12px; /* room for the hover lift + shadow */
  }
  .cteam__viewport::-webkit-scrollbar { display: none; }

  .cteam__track { list-style: none; margin: 0; padding: 0; display: flex; gap: clamp(16px, 2vw, 26px); }

  .cvoice {
    flex: 0 0 clamp(300px, 31vw, 372px); scroll-snap-align: start;
    display: flex; flex-direction: column; border: 1px solid var(--hairline-gold); border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.025); padding: clamp(26px, 2.4vw, 36px);
    transition: transform var(--t-med), border-color var(--t-med), box-shadow var(--t-med);
  }
  .cvoice:hover { transform: translateY(-4px); border-color: var(--hairline-gold-strong); box-shadow: var(--shadow-float); }
  .cvoice__quote-ic { color: var(--gold-light); opacity: 0.8; }
  .cvoice__quote { font-family: var(--font-serif); font-size: clamp(18px, 1.6vw, 21px); line-height: 1.5; color: var(--cream); margin: 16px 0 0; font-style: italic; flex: 1; }
  .cvoice__person { display: flex; align-items: center; gap: 14px; margin-top: 24px; padding-top: 22px; border-top: 1px solid var(--hairline-light); }
  .cvoice__avatar {
    flex-shrink: 0; width: 48px; height: 48px; border-radius: 50%; display: grid; place-items: center;
    background: linear-gradient(150deg, var(--gold), var(--gold-deep)); color: var(--navy-ink);
    font-family: var(--font-serif); font-weight: 600; font-size: 16px; letter-spacing: 0.02em;
  }
  .cvoice__id { display: flex; flex-direction: column; }
  .cvoice__name { font-weight: 500; font-size: 15px; color: var(--cream); }
  .cvoice__role { font-size: 12.5px; color: var(--gold-light); letter-spacing: 0.02em; }
  .cvoice__stats { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; margin: 20px 0 0; padding: 0; }
  .cvoice__stats li {
    font-size: 12px; letter-spacing: 0.02em; color: var(--white-90); padding: 6px 12px;
    border: 1px solid var(--hairline-gold); border-radius: 100px; background: rgba(184, 153, 104, 0.08);
  }

  /* ---------- Controls ---------- */
  .cteam__controls { display: flex; align-items: center; justify-content: space-between; gap: 24px; margin-top: clamp(22px, 2.6vw, 34px); }
  .cteam__progress { flex: 1; max-width: 460px; height: 2px; background: var(--hairline-light); border-radius: 2px; overflow: hidden; }
  .cteam__progress span {
    display: block; height: 100%; width: 0;
    background: linear-gradient(90deg, var(--gold-deep), var(--gold-light)); transition: width 140ms linear;
  }
  .cteam__btns { display: flex; gap: 10px; flex-shrink: 0; }
  .cteam__btn {
    width: 48px; height: 48px; border-radius: 50%; display: grid; place-items: center;
    border: 1px solid var(--hairline-gold); color: var(--cream); background: transparent;
    transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast), opacity var(--t-fast);
  }
  .cteam__btn:hover:not(:disabled) { background: var(--gold); color: var(--navy-ink); border-color: var(--gold); }
  .cteam__btn:disabled { opacity: 0.3; cursor: default; }
  .cteam__btn--prev :global(.icon) { transform: rotate(180deg); }

  .cteam__strip {
    margin-top: clamp(40px, 5vw, 64px); display: flex; align-items: center; justify-content: space-between;
    gap: 24px; flex-wrap: wrap; padding: clamp(26px, 3vw, 38px) clamp(28px, 3vw, 46px);
    border: 1px solid var(--hairline-gold-strong); border-radius: var(--radius-lg);
    background: linear-gradient(120deg, rgba(184, 153, 104, 0.14), rgba(11, 26, 46, 0.2));
  }
  .cteam__strip-text { margin: 0; font-family: var(--font-serif); font-size: clamp(21px, 2.4vw, 28px); color: var(--cream); letter-spacing: -0.01em; }

  @media (max-width: 720px) {
    .cvoice { flex-basis: 82%; }
    .cteam__controls { justify-content: flex-end; }
    .cteam__progress { display: none; }
  }
</style>

<script>
  const viewport = document.querySelector<HTMLElement>('[data-team-viewport]');
  const bar = document.querySelector<HTMLElement>('[data-team-bar]');
  const prevBtn = document.querySelector<HTMLButtonElement>('[data-team-prev]');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-team-next]');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (viewport) {
    const track = viewport.querySelector<HTMLElement>('.cteam__track');

    const step = () => {
      const card = viewport.querySelector<HTMLElement>('.cvoice');
      const gap = track ? parseFloat(getComputedStyle(track).columnGap || '24') || 24 : 24;
      return card ? card.getBoundingClientRect().width + gap : viewport.clientWidth * 0.85;
    };

    const update = () => {
      const max = viewport.scrollWidth - viewport.clientWidth;
      const p = max > 0 ? viewport.scrollLeft / max : 0;
      if (bar) bar.style.width = `${Math.min(100, Math.max(0, p * 100))}%`;
      if (prevBtn) prevBtn.disabled = viewport.scrollLeft <= 1;
      if (nextBtn) nextBtn.disabled = max <= 1 || viewport.scrollLeft >= max - 1;
    };

    let ticking = false;
    viewport.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { update(); ticking = false; });
    }, { passive: true });
    window.addEventListener('resize', update);

    const behavior: ScrollBehavior = reduce ? 'auto' : 'smooth';
    prevBtn?.addEventListener('click', () => viewport.scrollBy({ left: -step(), behavior }));
    nextBtn?.addEventListener('click', () => viewport.scrollBy({ left: step(), behavior }));

    update();
  }
</script>
