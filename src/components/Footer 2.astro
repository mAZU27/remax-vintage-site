---
import { site } from '../data/site';
import Icon from './Icon.astro';
import Button from './Button.astro';
import Crest from './Crest.astro';
import FinalBrand from './FinalBrand.astro';

const columns = [
  {
    title: 'Navegar',
    links: [
      { label: 'Comprar', href: '/imoveis' },
      { label: 'Arrendar', href: '/imoveis?fim=arrendar' },
      { label: 'Vender', href: '/#vender' },
      { label: 'Avaliação', href: '/#vender' },
      { label: 'Sobre Nós', href: '/sobre-nos' },
      { label: 'Apoio ao cliente', href: '/apoio' },
      { label: 'Carreiras', href: '/carreiras' },
      { label: 'Contactos', href: '/contacto' },
    ],
  },
  {
    title: 'Bairros',
    links: [
      { label: 'Foz do Douro', href: '/imoveis?bairro=foz-do-douro' },
      { label: 'Boavista', href: '/imoveis?bairro=boavista' },
      { label: 'Aldoar', href: '/imoveis?bairro=aldoar' },
      { label: 'Nevogilde', href: '/imoveis?bairro=nevogilde' },
      { label: 'Ribeira', href: '/imoveis?bairro=ribeira' },
      { label: 'Cedofeita', href: '/imoveis?bairro=cedofeita' },
      { label: 'Matosinhos', href: '/imoveis?bairro=matosinhos' },
    ],
  },
  {
    title: 'Recursos',
    links: [
      { label: 'Guia do Comprador', href: '/recursos' },
      { label: 'Guia do Vendedor', href: '/recursos' },
      { label: 'Estudos de Mercado', href: '/insights' },
      { label: 'Magazine', href: '/insights' },
      { label: 'Destaques', href: '/imoveis' },
      { label: 'Favoritos', href: '/favoritos' },
      { label: 'Comparar', href: '/comparar' },
    ],
  },
];

const legal = [
  { label: 'Termos e Condições', href: '/termos' },
  { label: 'Política de Privacidade', href: '/privacidade' },
  { label: 'Política de Cookies', href: '/cookies' },
  { label: 'Mediação Imobiliária', href: '/mediacao' },
  { label: 'Livro de Reclamações', href: 'https://www.livroreclamacoes.pt/', external: true },
];
---
<footer class="lux" id="footer">
  <div class="container lux__top">
    <!-- Brand + positioning + newsletter -->
    <div class="lux__brand" data-reveal>
      <a href="/" class="lux__logo" aria-label={`${site.name} — início`}>
        <img src={site.logo} alt={site.name} width="2587" height="386" />
      </a>
      <p class="lux__pitch">
        Residências exclusivas. Serviço extraordinário. O padrão global da
        RE/MAX Collection, com alma portuense.
      </p>

      <form class="lux__news" data-newsletter novalidate>
        <p class="lux__news-title">Receba propriedades exclusivas</p>
        <p class="lux__news-sub">Aceda em primeira mão às melhores oportunidades.</p>
        <div class="lux__news-row">
          <label class="sr-only" for="foot-email">O seu email</label>
          <div class="lux__field">
            <input id="foot-email" type="email" name="email" inputmode="email" autocomplete="email" required placeholder="O seu email" />
          </div>
          <Button type="submit" variant="gold" class="lux__news-btn">Subscrever</Button>
        </div>
        <p class="lux__news-note" data-news-note>
          <Icon name="shield-check" size={14} stroke={1.6} />
          Respeitamos a sua privacidade. Pode cancelar a qualquer momento.
        </p>
        <p class="lux__news-success" data-news-success hidden>
          <Icon name="shield-check" size={15} stroke={1.7} /> Subscrição confirmada — bem-vindo à coleção.
        </p>
      </form>

      <div class="lux__social">
        {site.social.map((s) => (
          <a href={s.href} class="lux__social-link" aria-label={s.label} target="_blank" rel="noopener noreferrer">
            <Icon name={s.icon} size={17} stroke={1.6} />
          </a>
        ))}
      </div>
    </div>

    <!-- Navigation + contact + legal + crest -->
    <div class="lux__right">
      <nav class="lux__cols" aria-label="Rodapé">
        {columns.map((col, i) => (
          <div class="lux__col" data-reveal style={`--reveal-delay: ${120 + i * 70}ms`}>
            <h2 class="lux__col-title">{col.title}</h2>
            <ul>
              {col.links.map((l) => (
                <li><a href={l.href} class="lux__link">{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))}

        <div class="lux__col lux__col--contact" data-reveal style="--reveal-delay: 330ms">
          <h2 class="lux__col-title">Contacto</h2>
          <ul class="lux__contact">
            <li>
              <Icon name="pin" size={16} stroke={1.6} />
              <span>{site.address.map((line, i) => (<>{i > 0 && <br />}{line}</>))}</span>
            </li>
            <li><a href={site.phoneHref} class="lux__link"><Icon name="phone" size={16} stroke={1.6} /> {site.phone}</a></li>
            <li><a href={`mailto:${site.email}`} class="lux__link"><Icon name="mail" size={16} stroke={1.6} /> {site.email}</a></li>
            <li>
              <Icon name="clock" size={16} stroke={1.6} />
              <span>{site.hours.map((line, i) => (<>{i > 0 && <br />}{line}</>))}</span>
            </li>
          </ul>
        </div>

        <div class="lux__col" data-reveal style="--reveal-delay: 400ms">
          <h2 class="lux__col-title">Legal</h2>
          <ul>
            {legal.map((l) => (
              <li>
                <a href={l.href} class="lux__link" {...l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}>{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </nav>

      <div class="lux__crest" data-reveal style="--reveal-delay: 470ms">
        <Crest size={62} label />
      </div>
    </div>
  </div>

  <!-- Porto skyline line-art — fades in + draws left→right on reveal.
       pathLength normalises every segment to 1 so one dash rule drives them. -->
  <svg class="lux__skyline" viewBox="0 0 1200 130" fill="none" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
    <path style="--sd: 0ms" pathLength="1" d="M0 116 L0 92 L24 92 L24 78 L58 78 L58 98 L92 98 L92 66 L116 66 L116 92 L146 92 L146 106 L188 106" />
    <path style="--sd: 200ms" pathLength="1" d="M204 116 L204 44 Q212 26 220 44 L220 116 M212 44 L212 22" />
    <path style="--sd: 330ms" pathLength="1" d="M236 116 L236 88 L276 88 L276 70 L316 70 L316 96 L356 96 L356 82 L412 82 L412 116" />
    <path style="--sd: 480ms" pathLength="1" d="M456 116 L456 52 M740 116 L740 52 M444 52 L752 52 M456 114 Q598 44 740 114" />
    <path style="--sd: 700ms" pathLength="1" d="M772 116 L772 90 L820 90 L820 72 L878 72 L878 96 L936 96 L936 80 L1004 80 L1004 98 L1062 98 L1062 86 L1118 86 L1118 108 L1200 108" />
    <path class="lux__skyline-base" style="--sd: 120ms" pathLength="1" d="M0 116 L1200 116" />
  </svg>
</footer>

<FinalBrand />

<style>
  .lux {
    position: relative; background: var(--navy-ink); color: var(--cream);
    padding: clamp(64px, 7vw, 100px) var(--gutter) clamp(90px, 11vw, 150px);
    border-top: 1px solid var(--hairline-gold);
  }

  .lux__top {
    display: grid; grid-template-columns: minmax(0, 1.3fr) minmax(0, 2.85fr);
    gap: clamp(40px, 5vw, 84px); align-items: start;
  }

  /* ---- Brand block ---- */
  .lux__logo img { height: 40px; width: auto; }
  .lux__pitch { color: var(--white-50); font-size: 14.5px; line-height: 1.7; margin: 26px 0 0; max-width: 38ch; }

  .lux__news { margin-top: 30px; max-width: 420px; }
  .lux__news-title { font-family: var(--font-sans); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold-light); font-weight: 500; margin: 0; }
  .lux__news-sub { font-size: 13.5px; color: var(--white-50); margin: 9px 0 0; line-height: 1.5; }
  .lux__news-row { display: grid; grid-template-columns: 1fr auto; gap: 12px; margin-top: 16px; }
  .lux__field {
    display: flex; align-items: center; padding: 0 16px;
    background: rgba(244, 237, 222, 0.05); border: 1px solid var(--hairline-gold); border-radius: 2px;
    transition: border-color var(--t-fast), background var(--t-fast), box-shadow var(--t-fast);
  }
  .lux__field:focus-within {
    border-color: var(--gold-light); background: rgba(244, 237, 222, 0.09);
    box-shadow: 0 0 0 4px rgba(184, 153, 104, 0.16), 0 0 22px -6px rgba(212, 187, 133, 0.4);
  }
  .lux__field input { flex: 1; min-width: 0; background: none; border: none; color: var(--cream); font-size: 14.5px; padding: 14px 0; letter-spacing: 0.02em; outline: none; }
  .lux__field input::placeholder { color: var(--white-50); }
  :global(.lux__news-btn) { white-space: nowrap; padding-inline: 24px; }
  .lux__news-note { display: flex; align-items: center; gap: 8px; margin: 14px 0 0; font-size: 12px; color: var(--white-50); line-height: 1.5; }
  .lux__news-note :global(.icon) { color: var(--gold); flex-shrink: 0; }
  .lux__news-success { display: none; align-items: center; gap: 8px; margin: 14px 0 0; font-size: 13.5px; color: var(--gold-light); letter-spacing: 0.02em; }
  .lux__news-success:not([hidden]) { display: inline-flex; }
  .lux__field.is-invalid { border-color: #C98A6A; }

  .lux__social { display: flex; gap: 11px; margin-top: 30px; }
  .lux__social-link {
    display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px;
    border: 1px solid var(--hairline-gold); border-radius: 50%; color: var(--white-70);
    transition: color var(--t-fast), border-color var(--t-fast), background var(--t-fast), transform var(--t-fast);
  }
  .lux__social-link:hover { color: var(--navy); background: var(--gold-light); border-color: var(--gold-light); transform: translateY(-2px); }

  /* ---- Right: columns + crest ---- */
  .lux__right { position: relative; }
  .lux__cols { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: clamp(16px, 2vw, 34px); }
  .lux__col-title {
    font-family: var(--font-sans); font-size: 11px; font-weight: 500; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--gold-light); margin: 0 0 20px; padding-bottom: 14px;
    border-bottom: 1px solid var(--hairline-light);
  }
  .lux__col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .lux__link {
    position: relative; display: inline-flex; align-items: flex-start; gap: 9px; color: var(--white-70);
    text-decoration: none; font-size: 13.5px; line-height: 1.45; letter-spacing: 0.01em;
    transition: color var(--t-fast);
  }
  .lux__link::after {
    content: ""; position: absolute; left: 0; bottom: -2px; width: 100%; height: 1px;
    background: var(--gold-light); transform: scaleX(0); transform-origin: left; transition: transform var(--t-med);
  }
  .lux__link:hover { color: var(--gold-light); }
  .lux__link:hover::after { transform: scaleX(1); }
  .lux__link :global(.icon) { color: var(--gold); flex-shrink: 0; margin-top: 1px; }

  .lux__contact { gap: 16px !important; }
  .lux__contact li { display: flex; align-items: flex-start; gap: 9px; font-size: 13.5px; color: var(--white-70); line-height: 1.5; }
  .lux__contact li :global(.icon) { color: var(--gold); flex-shrink: 0; margin-top: 2px; }
  .lux__contact .lux__link { gap: 9px; }

  .lux__crest { display: flex; justify-content: flex-end; margin-top: clamp(36px, 4vw, 56px); }

  /* ---- Skyline ---- */
  .lux__skyline {
    position: relative; z-index: 0; display: block; width: 100%; height: clamp(72px, 10vw, 120px);
    margin: clamp(40px, 5vw, 70px) 0 0; color: var(--gold);
    opacity: 0; transition: opacity 1.1s var(--t-ease-emph);
  }
  .lux__skyline.is-drawn { opacity: 0.34; }
  .lux__skyline path { stroke: currentColor; stroke-width: 1.3; stroke-linecap: round; stroke-linejoin: round; vector-effect: non-scaling-stroke; stroke-dasharray: 1; stroke-dashoffset: 1; }
  .lux__skyline-base { opacity: 0.5; }
  .lux__skyline.is-drawn path { animation: luxDraw 1.7s var(--t-ease-emph) calc(0.1s + var(--sd, 0ms)) forwards; }
  @keyframes luxDraw { to { stroke-dashoffset: 0; } }

  /* ---- Responsive ---- */
  @media (max-width: 1080px) {
    .lux__top { grid-template-columns: 1fr; gap: 52px; }
    .lux__brand { max-width: 560px; }
  }
  @media (max-width: 820px) {
    .lux__cols { grid-template-columns: repeat(3, 1fr); row-gap: 38px; }
    .lux__crest { justify-content: flex-start; }
  }
  @media (max-width: 540px) {
    .lux__cols { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 380px) {
    .lux__news-row { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lux__skyline { opacity: 0.34; }
    .lux__skyline path { stroke-dashoffset: 0; }
  }
</style>

<script>
  // Newsletter — front-end only (no backend wired). Validate + confirm.
  document.querySelectorAll('[data-newsletter]').forEach((formEl) => {
    const form = formEl as HTMLFormElement;
    if (form.dataset.bound) return;
    form.dataset.bound = '1';
    const field = form.querySelector('.lux__field, .news__field') as HTMLElement | null;
    const input = form.querySelector('input[type="email"]') as HTMLInputElement | null;
    const note = form.querySelector('[data-news-note]') as HTMLElement | null;
    const success = form.querySelector('[data-news-success]') as HTMLElement | null;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!input || !input.checkValidity()) {
        field?.classList.add('is-invalid');
        input?.focus();
        return;
      }
      field?.classList.remove('is-invalid');
      if (field) field.style.display = 'none';
      form.querySelector('[type="submit"]')?.setAttribute('hidden', '');
      if (note) note.hidden = true;
      if (success) success.hidden = false;
    });
    input?.addEventListener('input', () => field?.classList.remove('is-invalid'));
  });

  // Skyline draws when it scrolls into view.
  const skyline = document.querySelector('.lux__skyline');
  if (skyline) {
    if (!('IntersectionObserver' in window)) {
      skyline.classList.add('is-drawn');
    } else {
      const so = new IntersectionObserver(
        (entries, obs) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('is-drawn'); obs.unobserve(e.target); }
        }),
        { rootMargin: '0px 0px -10% 0px' }
      );
      so.observe(skyline);
    }
  }
</script>
