---
// Resource/guide card (cover image + kicker + title + "Ler guia"). Guide
// content is not written yet — CTA bridges to /insights (see data/faqs.ts).
import Icon from './Icon.astro';
import type { Guide } from '../data/faqs';

interface Props {
  guide: Guide;
  index?: number;
}
const { guide: g, index = 0 } = Astro.props;
---
<a class="guide" href={g.href} data-reveal style={`--reveal-delay:${index * 80}ms`}>
  <span class="guide__media">
    <img src={g.image} alt="" loading="lazy" decoding="async" width="800" height="600" />
    <span class="guide__scrim" aria-hidden="true"></span>
    <span class="guide__kicker">{g.kicker}</span>
  </span>
  <span class="guide__body">
    <span class="guide__title">{g.title}</span>
    <span class="btn-link guide__cta">Ler guia <Icon name="arrow" size={14} stroke={1.8} /></span>
  </span>
</a>

<style>
  .guide {
    display: flex; flex-direction: column; text-decoration: none; color: var(--ink);
    background: var(--cream-soft); border: 1px solid var(--ink-10); border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--t-med), border-color var(--t-med), box-shadow var(--t-med);
  }
  .guide:hover { transform: translateY(-4px); border-color: var(--hairline-gold-strong); box-shadow: var(--shadow-card); }
  .guide__media { position: relative; display: block; aspect-ratio: 4 / 3; overflow: hidden; }
  .guide__media img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--t-slow) var(--t-ease-emph); }
  .guide:hover .guide__media img { transform: scale(1.04); }
  .guide__scrim { position: absolute; inset: 0; background: linear-gradient(to top, rgba(8,17,30,0.55), transparent 55%); }
  .guide__kicker {
    position: absolute; top: 14px; left: 14px;
    font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 500;
    color: var(--navy-ink); background: var(--gold-light); padding: 6px 11px; border-radius: 3px;
  }
  .guide__body { display: flex; flex-direction: column; flex: 1; padding: clamp(20px, 2vw, 26px); }
  .guide__title { font-family: var(--font-serif); font-weight: 500; font-size: clamp(19px, 1.5vw, 22px); color: var(--ink); line-height: 1.2; letter-spacing: -0.01em; flex: 1; }
  .guide__cta { margin-top: 18px; font-size: 12.5px; }
</style>
