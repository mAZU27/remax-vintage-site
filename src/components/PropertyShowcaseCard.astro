---
// A single slide in the FeaturedPropertiesExperience carousel.
// Dark, premium card. Base styles render a fully-legible card (works with no
// JS); the parent carousel (.fpe__track.is-live) dims/scales non-active slides
// and reveals the energy chip + CTA only on the centred (.is-active) card.
import Icon from './Icon.astro';
import { type Property, formatPrice, statusLabel, categoryOf } from '../data/properties';

interface Props {
  property: Property;
  index: number;
}
const { property: p, index } = Astro.props;
const href = `/imoveis/${p.slug}`;
const cat = categoryOf(p);
const showBadge = p.badge && p.status === 'disponivel';
---
<article
  class="pscard"
  data-slide
  data-property={p.slug}
  data-zona={p.neighborhood}
  data-cat={cat}
  data-price={p.price ?? ''}
  data-beds={p.beds}
  data-index={index}
>
  <div class="pscard__media">
    <img
      src={p.image}
      alt={`${p.title} — ${p.neighborhoodName}`}
      loading="lazy"
      decoding="async"
      width="1600"
      height="1067"
    />
    <span class="pscard__shade" aria-hidden="true"></span>

    <div class="pscard__chips">
      {p.featured && <span class="pscard__chip pscard__chip--feat">Em destaque</span>}
      {showBadge && <span class="pscard__chip pscard__chip--badge">{p.badge}</span>}
      {p.status !== 'disponivel' && (
        <span class={`pscard__chip pscard__chip--status is-${p.status}`}>{statusLabel[p.status]}</span>
      )}
    </div>

    <button
      class="pscard__fav"
      type="button"
      aria-pressed="false"
      aria-label={`Guardar ${p.title} nos favoritos`}
      data-fav-toggle
      data-slug={p.slug}
    >
      <Icon name="heart" size={18} stroke={1.7} />
    </button>
  </div>

  <div class="pscard__body">
    <span class="pscard__hood">{p.neighborhoodName}</span>
    <h3 class="pscard__title"><a href={href}>{p.title}</a></h3>
    <p class="pscard__price">{formatPrice(p.price)}</p>

    <div class="pscard__foot">
      <ul class="pscard__meta">
        <li class="psmeta">
          <Icon name="bed" size={18} stroke={1.5} />
          <span class="psmeta__t"><b>{p.beds}</b><small>Quartos</small></span>
        </li>
        <li class="psmeta">
          <Icon name="bath" size={18} stroke={1.5} />
          <span class="psmeta__t"><b>{p.baths}</b><small>Casas de banho</small></span>
        </li>
        <li class="psmeta">
          <Icon name="ruler" size={18} stroke={1.5} />
          <span class="psmeta__t"><b>{p.area} m²</b><small>Área bruta</small></span>
        </li>
        <li class="psmeta psmeta--energy">
          <Icon name="bolt" size={18} stroke={1.5} />
          <span class="psmeta__t"><b>{p.energy}</b><small>Classe energética</small></span>
        </li>
      </ul>

      <a class="pscard__cta" href={href}>
        <span>Ver detalhes</span><Icon name="arrow" size={16} stroke={1.7} />
      </a>
    </div>
  </div>
</article>

<style>
  .pscard {
    position: relative; display: flex; flex-direction: column; height: 100%;
    background: linear-gradient(180deg, rgba(16, 39, 66, 0.92), rgba(11, 26, 46, 0.96));
    border: 1px solid var(--hairline-gold); border-radius: var(--radius-lg); overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .pscard__media { position: relative; aspect-ratio: 16 / 11; overflow: hidden; background: var(--navy-soft); }
  .pscard__media img {
    width: 100%; height: 100%; object-fit: cover; transition: transform var(--t-slow) var(--t-ease-emph);
  }
  .pscard__shade {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(11, 26, 46, 0.18) 0%, transparent 32%, transparent 60%, rgba(11, 26, 46, 0.6) 100%);
  }

  .pscard__chips { position: absolute; top: 16px; left: 16px; display: flex; flex-wrap: wrap; gap: 8px; max-width: calc(100% - 76px); }
  .pscard__chip {
    font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 500;
    padding: 7px 12px; border-radius: 3px; backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
  }
  .pscard__chip--feat { background: var(--gold-light); color: var(--navy-ink); }
  .pscard__chip--badge { background: rgba(11, 26, 46, 0.66); color: var(--cream); border: 1px solid var(--hairline-gold-strong); }
  .pscard__chip--status { background: rgba(11, 26, 46, 0.78); color: var(--cream); border: 1px solid var(--hairline-gold); }
  .pscard__chip--status.is-reservado { background: rgba(154, 126, 80, 0.92); color: var(--navy-ink); border: 0; }

  .pscard__fav {
    position: absolute; top: 14px; right: 14px; z-index: 2;
    width: 40px; height: 40px; display: grid; place-items: center; border-radius: 50%;
    background: rgba(11, 26, 46, 0.5); color: var(--cream);
    border: 1px solid var(--hairline-gold); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    transition: background var(--t-fast), color var(--t-fast), transform var(--t-fast), border-color var(--t-fast);
  }
  .pscard__fav:hover { background: rgba(11, 26, 46, 0.75); border-color: var(--gold); transform: scale(1.08); }
  .pscard__fav[aria-pressed='true'] { background: var(--gold); color: var(--navy-ink); border-color: var(--gold); }
  .pscard__fav[aria-pressed='true'] :global(.icon) { fill: var(--navy-ink); }

  .pscard__body { display: flex; flex-direction: column; flex: 1; padding: clamp(20px, 2vw, 28px); }
  .pscard__hood { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold-light); font-weight: 500; }
  .pscard__title { font-family: var(--font-serif); font-weight: 500; font-size: clamp(22px, 2.2vw, 30px); line-height: 1.1; letter-spacing: -0.01em; margin: 12px 0 0; }
  .pscard__title a { color: var(--cream); text-decoration: none; transition: color var(--t-fast); }
  .pscard__title a::after { content: ''; position: absolute; inset: 0; } /* full-card link */
  .pscard:hover .pscard__title a { color: var(--gold-light); }
  .pscard__price { font-family: var(--font-serif); font-size: clamp(22px, 2.2vw, 28px); color: var(--gold-light); margin: 8px 0 0; font-weight: 500; }

  .pscard__foot {
    margin-top: auto; padding-top: 18px; border-top: 1px solid var(--hairline-light);
    display: flex; align-items: flex-end; justify-content: space-between; gap: 18px; flex-wrap: wrap;
  }
  .pscard__meta { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 14px 22px; }
  .psmeta { display: inline-flex; align-items: center; gap: 9px; }
  .psmeta :global(.icon) { color: var(--gold-light); flex-shrink: 0; }
  .psmeta__t { display: flex; flex-direction: column; line-height: 1.15; }
  .psmeta__t b { font-weight: 500; font-size: 14px; color: var(--cream); }
  .psmeta__t small { font-size: 9.5px; letter-spacing: 0.13em; text-transform: uppercase; color: var(--white-50); margin-top: 2px; }

  .pscard__cta {
    position: relative; z-index: 2; flex-shrink: 0;
    display: inline-flex; align-items: center; gap: 9px; padding: 12px 20px;
    border: 1px solid var(--gold); border-radius: 100px; color: var(--gold-light);
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; text-decoration: none; white-space: nowrap;
    transition: background var(--t-fast), color var(--t-fast), box-shadow var(--t-fast);
  }
  .pscard__cta :global(.arrow) { transition: transform var(--t-fast); }
  .pscard__cta:hover { background: var(--gold); color: var(--navy-ink); box-shadow: 0 0 22px -8px rgba(184, 153, 104, 0.7); }
  .pscard__cta:hover :global(.arrow) { transform: translateX(4px); }

  @media (max-width: 600px) {
    .pscard__foot { flex-direction: column; align-items: stretch; }
    .pscard__cta { justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pscard__media img, .pscard__cta :global(.arrow) { transition: none; }
  }
</style>
