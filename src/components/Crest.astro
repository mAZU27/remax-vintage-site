---
// Brand crest — a hairline shield with the "VC" (Vintage · Collection)
// serif monogram. Decorative; the brand name is exposed elsewhere.
interface Props {
  size?: number;
  label?: boolean;
  class?: string;
}
const { size = 56, label = false, class: cls = '' } = Astro.props;
---
<span class:list={['crest', cls]} style={`--crest-size:${size}px`} aria-hidden="true">
  <span class="crest__shield">
    <svg viewBox="0 0 100 120" fill="none" preserveAspectRatio="xMidYMid meet">
      <path d="M9 11 H91 V62 Q91 95 50 115 Q9 95 9 62 Z" />
    </svg>
    <span class="crest__mono">VC</span>
  </span>
  {label && <span class="crest__label">Excelência Imobiliária</span>}
</span>

<style>
  .crest { display: inline-flex; flex-direction: column; align-items: center; gap: 12px; }
  .crest__shield { position: relative; width: var(--crest-size); height: calc(var(--crest-size) * 1.2); }
  .crest__shield svg { width: 100%; height: 100%; }
  .crest__shield path {
    stroke: var(--gold); stroke-width: 1.4; vector-effect: non-scaling-stroke;
    fill: rgba(184, 153, 104, 0.04);
  }
  .crest__mono {
    position: absolute; inset: 0; display: grid; place-items: center; padding-bottom: 9%;
    font-family: var(--font-serif); font-weight: 500; color: var(--gold-light);
    font-size: calc(var(--crest-size) * 0.4); letter-spacing: -0.05em;
  }
  .crest__label {
    font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--gold); text-align: center; line-height: 1.4;
  }
</style>
