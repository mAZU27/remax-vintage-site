---
// Prova social — premium "histórias reais" showcase (testimonials in site.ts).
// A horizontal scroll-snap carousel: cards sit in a row, each snapping to centre.
// Theme pill, elegant gold quote mark, a subtle Porto line-art engraving
// (bridge/façade/tower), navy name + uppercase gold location. Below: a thin
// progress line bound to scroll position, a counter, verified microcopy, and two
// circular gold arrows.
//
// Progressive enhancement — without JS the deck is already a native horizontal
// scroller (overflow-x + scroll-snap) and the controls stay hidden. JS adds
// `.is-ready` to reveal the controls and layers premium interaction on top:
// drag-to-scroll (mouse), arrow + keyboard navigation, and live progress/counter
// sync. SCROLL_SENSITIVITY tunes drag feel. Vertical wheel is never hijacked.
import { testimonials } from '../data/site';
import SectionEyebrow from './SectionEyebrow.astro';

const total = testimonials.length;
const pad = (n: number) => String(n).padStart(2, '0');
// First paint mirrors the reference: Sofia A. (index 4 → "05 / 12").
const start = Math.min(4, total - 1);
---
<section class="rev" id="testemunhos" aria-labelledby="rev-title" data-rev>
  <div class="rev__glow" aria-hidden="true"></div>

  <div class="rev__inner container">
    <header class="rev__head">
      <SectionEyebrow text="A experiência de quem confiou" center />
      <h2 id="rev-title" class="rev__title" data-reveal style="--reveal-delay:80ms">
        Histórias reais. Confiança que <em class="rev__se">se vê.</em>
      </h2>
      <p class="rev__sub" data-reveal style="--reveal-delay:160ms">
        Mais do que imóveis, entregamos relações de confiança e resultados que fazem a diferença.
      </p>
      <div class="rev__diamond" data-reveal style="--reveal-delay:220ms" aria-hidden="true"><i></i></div>
    </header>

    <div
      class="rev__stage"
      data-reveal
      style="--reveal-delay:120ms"
      role="group"
      aria-roledescription="carrossel"
      aria-label="Testemunhos de clientes"
      tabindex="0"
    >
      <ul class="rev__deck">
        {testimonials.map((t, i) => (
          <li class="rev__card" data-i={i}>
            <article class="rev__card-inner">
              <div class="rev__card-top">
                <span class="rev__pill">{t.theme}</span>
                <span class="rev__landmark" aria-hidden="true">
                  {t.icon === 'bridge' && (
                    <svg viewBox="0 0 64 40" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M2 13H62" />
                      <path d="M9 13V31M55 13V31" />
                      <path d="M9 29Q32 7 55 29" />
                      <path d="M2 31H62" />
                      <path d="M18 25V31M25 21V31M32 19V31M39 21V31M46 25V31" />
                    </svg>
                  )}
                  {t.icon === 'facade' && (
                    <svg viewBox="0 0 44 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M6 19 22 6l16 13" />
                      <path d="M9 19v24h26V19" />
                      <path d="M18 43V31h8v12" />
                      <path d="M12 24h5v6h-5zM19.5 24h5v6h-5zM27 24h5v6h-5z" />
                    </svg>
                  )}
                  {t.icon === 'tower' && (
                    <svg viewBox="0 0 32 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 46h22" />
                      <path d="M9 46V20h14v26" />
                      <path d="M8 20h16" />
                      <path d="M11 20v-8h10v8" />
                      <path d="M13 12Q16 3 19 12" />
                      <path d="M16 3V0.5" />
                      <path d="M14 28h4M14 35h4" />
                    </svg>
                  )}
                </span>
              </div>

              <span class="rev__qmark" aria-hidden="true">&#8220;</span>
              <blockquote class="rev__quote">{t.quote}</blockquote>

              <footer class="rev__cite">
                <span class="rev__name">{t.name}</span>
                <span class="rev__loc">{t.location}</span>
              </footer>
            </article>
          </li>
        ))}
      </ul>
    </div>

    <div class="rev__foot">
      <div class="rev__progress" aria-hidden="true"><span class="rev__bar" data-rev-bar></span></div>
      <div class="rev__foot-row">
        <span class="rev__count" aria-hidden="true"><b data-rev-current>{pad(start + 1)}</b><i>/</i><span>{pad(total)}</span></span>
        <span class="rev__verified">Avaliações verificadas de clientes reais</span>
        <div class="rev__arrows">
          <button type="button" class="rev__arrow rev__arrow--prev" data-rev-prev aria-label="Testemunho anterior">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </button>
          <button type="button" class="rev__arrow rev__arrow--next" data-rev-next aria-label="Testemunho seguinte">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---------- Section shell ---------- */
  .rev {
    position: relative;
    background: var(--cream);
    color: var(--ink);
    padding: clamp(80px, 9vw, 116px) var(--gutter) clamp(70px, 7vw, 96px);
    overflow: hidden;
  }
  .rev__glow {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background:
      radial-gradient(58% 44% at 50% 0%, var(--cream-soft), transparent 70%),
      radial-gradient(52% 40% at 50% 100%, var(--hairline-gold), transparent 72%);
  }
  .rev__inner { position: relative; z-index: 1; }

  /* ---------- Header ---------- */
  .rev__head { text-align: center; max-width: 760px; margin: 0 auto clamp(48px, 5vw, 74px); }
  .rev__title {
    margin: 22px 0 0; font-family: var(--font-serif); font-weight: 500;
    font-size: clamp(38px, 5vw, 66px); line-height: 1.05; letter-spacing: -0.018em;
    color: var(--navy); text-wrap: balance;
  }
  .rev__se { font-family: var(--font-serif); font-style: italic; font-weight: 400; color: var(--gold); }
  .rev__sub {
    max-width: 520px; margin: 22px auto 0;
    font-size: var(--fs-body-lg); line-height: 1.6; color: var(--ink-60); text-wrap: pretty;
  }
  .rev__diamond { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 28px; }
  .rev__diamond::before, .rev__diamond::after {
    content: ""; width: 38px; height: 1px; background: var(--hairline-gold-strong);
  }
  .rev__diamond i { width: 8px; height: 8px; background: var(--gold); transform: rotate(45deg); }

  /* ---------- Deck: default (no-JS) flex scroller ---------- */
  .rev__stage { position: relative; }
  .rev__deck {
    list-style: none; margin: 0; padding: 8px 4px;
    display: flex; gap: clamp(16px, 2vw, 28px);
    /* Horizontal-only scroller. overflow-y stays visible so vertical page scroll
       is never trapped; overscroll-behavior stops horizontal scroll-chaining. */
    overflow-x: auto; overflow-y: visible; overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch; scrollbar-width: none;
  }
  .rev__deck::-webkit-scrollbar { display: none; }
  .rev__card { flex: 0 0 clamp(300px, 30vw, 380px); scroll-snap-align: center; margin: 0; }

  /* ---------- Card surface ---------- */
  .rev__card-inner {
    height: 100%; min-height: clamp(340px, 32vw, 420px);
    display: flex; flex-direction: column;
    background: var(--cream-soft);
    border: 1px solid var(--hairline-gold);
    border-radius: var(--radius-lg);
    padding: clamp(28px, 2.6vw, 40px);
    box-shadow: var(--shadow-card);
  }
  .rev__card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
  .rev__pill {
    font-family: var(--font-sans); font-size: 10.5px; font-weight: 500;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold-deep);
    border: 1px solid var(--hairline-gold-strong); border-radius: 100px; padding: 6px 13px;
  }
  .rev__landmark { color: var(--gold); opacity: 0.5; flex: none; }
  .rev__landmark svg { height: 40px; width: auto; }
  .rev__qmark {
    display: block; margin-top: 16px;
    font-family: var(--font-serif); font-style: italic; color: var(--gold);
    font-size: 66px; line-height: 0.6; opacity: 0.5;
  }
  .rev__quote {
    flex: 1; margin: 8px 0 0; font-family: var(--font-serif); font-style: italic; font-weight: 400;
    font-size: clamp(18px, 1.5vw, 22px); line-height: 1.46; letter-spacing: -0.01em; color: var(--navy);
  }
  .rev__cite {
    margin-top: 24px; padding-top: 18px; border-top: 1px solid var(--hairline-gold);
    display: flex; flex-direction: column; gap: 5px;
  }
  .rev__name { font-size: 15px; font-weight: 600; color: var(--navy); }
  .rev__loc { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold-deep); }

  /* ---------- Enhanced horizontal scroller (JS) ---------- */
  .rev.is-ready .rev__deck { cursor: grab; scroll-behavior: smooth; }
  .rev.is-ready .rev__deck.is-dragging {
    cursor: grabbing; scroll-snap-type: none; scroll-behavior: auto; user-select: none;
  }
  .rev.is-ready .rev__card.is-center .rev__card-inner {
    border-color: var(--hairline-gold-strong); box-shadow: var(--shadow-card-lg);
  }

  /* ---------- Foot: progress + counter + verified + arrows ---------- */
  .rev__foot { margin-top: clamp(34px, 4vw, 56px); }
  .rev__progress { display: none; height: 2px; background: var(--ink-10); border-radius: 2px; overflow: hidden; }
  .rev.is-ready .rev__progress { display: block; }
  .rev__bar {
    display: block; height: 100%; width: 0;
    background: linear-gradient(90deg, var(--gold-deep), var(--gold-light));
    transition: width var(--t-med) var(--t-ease-emph);
  }
  .rev__foot-row { margin-top: 22px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 20px; }
  .rev__count { display: none; justify-self: start; font-family: var(--font-serif); font-size: 17px; letter-spacing: 0.04em; color: var(--ink-40); }
  .rev.is-ready .rev__count { display: block; }
  .rev__count b { color: var(--gold-deep); font-weight: 500; }
  .rev__count i { font-style: normal; margin: 0 7px; color: var(--ink-20); }
  .rev__verified {
    justify-self: center; text-align: center; font-family: var(--font-sans);
    font-size: 11px; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold-deep);
  }
  .rev__arrows { display: none; gap: 12px; justify-self: end; }
  .rev.is-ready .rev__arrows { display: flex; }
  .rev__arrow {
    width: 48px; height: 48px; border-radius: 50%; display: grid; place-items: center;
    border: 1px solid var(--hairline-gold-strong); color: var(--navy); background: transparent;
    transition: background var(--t-fast), border-color var(--t-fast), color var(--t-fast), transform var(--t-fast);
  }
  .rev__arrow:hover { background: var(--cream-warm); border-color: var(--gold); }
  .rev__arrow:active { transform: scale(0.94); }
  .rev__arrow svg { width: 20px; height: 20px; }
  .rev__arrow--prev svg { transform: rotate(180deg); }

  /* ---------- Responsive ---------- */
  @media (max-width: 720px) {
    .rev__foot-row {
      grid-template-columns: auto 1fr; grid-template-areas: "count arrows" "verified verified"; row-gap: 20px;
    }
    .rev__count { grid-area: count; }
    .rev__arrows { grid-area: arrows; }
    .rev__verified { grid-area: verified; }
  }
</style>

<script>
  // Sensibilidade do arrasto/roda. Mais alto = mais rápido. Fácil de afinar.
  const SCROLL_SENSITIVITY = 1.4;

  const root = document.querySelector<HTMLElement>('[data-rev]');

  if (root) {
    const deck = root.querySelector<HTMLElement>('.rev__deck');
    const cards = Array.from(root.querySelectorAll<HTMLElement>('.rev__card'));
    const bar = root.querySelector<HTMLElement>('[data-rev-bar]');
    const current = root.querySelector<HTMLElement>('[data-rev-current]');
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-rev-prev]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-rev-next]');
    const stage = root.querySelector<HTMLElement>('.rev__stage');
    const total = cards.length;
    const pad = (n: number): string => String(n).padStart(2, '0');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (deck && total > 0) {
      let active = -1;

      // Index of the card whose centre is closest to the viewport centre.
      const nearestIndex = (): number => {
        const mid = deck.scrollLeft + deck.clientWidth / 2;
        let best = 0;
        let bestDist = Infinity;
        cards.forEach((card, i) => {
          const cc = card.offsetLeft + card.offsetWidth / 2;
          const d = Math.abs(cc - mid);
          if (d < bestDist) { bestDist = d; best = i; }
        });
        return best;
      };

      // Bind progress line + counter + centre-highlight to the scroll position.
      const sync = (): void => {
        const max = deck.scrollWidth - deck.clientWidth;
        const ratio = max > 0 ? deck.scrollLeft / max : 0;
        if (bar) bar.style.width = `${Math.max(0, Math.min(1, ratio)) * 100}%`;
        const idx = nearestIndex();
        if (idx !== active) {
          active = idx;
          cards.forEach((card, i) => card.classList.toggle('is-center', i === idx));
          if (current) current.textContent = pad(idx + 1);
        }
      };

      const scrollToCard = (i: number): void => {
        const idx = Math.max(0, Math.min(total - 1, i));
        const card = cards[idx];
        if (!card) return;
        const left = card.offsetLeft - (deck.clientWidth - card.offsetWidth) / 2;
        deck.scrollTo({ left, behavior: reduce ? 'auto' : 'smooth' });
      };

      prevBtn?.addEventListener('click', () => scrollToCard(active - 1));
      nextBtn?.addEventListener('click', () => scrollToCard(active + 1));

      stage?.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowLeft') { e.preventDefault(); scrollToCard(active - 1); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); scrollToCard(active + 1); }
      });

      // No wheel hijack: vertical wheel/trackpad (deltaY) must always scroll the
      // page. Horizontal browsing of the deck stays available via drag, the
      // arrows/keyboard, and the trackpad's own horizontal gesture (deltaX, which
      // the native overflow-x scroller handles without any JS).

      // Drag-to-scroll (mouse only; touch keeps native momentum scrolling).
      let dragging = false;
      let startX = 0;
      let startScroll = 0;
      let moved = false;
      deck.addEventListener('pointerdown', (e: PointerEvent) => {
        if (e.pointerType !== 'mouse') return;
        dragging = true;
        moved = false;
        startX = e.clientX;
        startScroll = deck.scrollLeft;
        deck.classList.add('is-dragging');
        deck.setPointerCapture(e.pointerId);
      });
      deck.addEventListener('pointermove', (e: PointerEvent) => {
        if (!dragging) return;
        const delta = e.clientX - startX;
        if (Math.abs(delta) > 3) moved = true;
        deck.scrollLeft = startScroll - delta * SCROLL_SENSITIVITY;
      });
      const endDrag = (e: PointerEvent): void => {
        if (!dragging) return;
        dragging = false;
        deck.classList.remove('is-dragging'); // re-arms scroll-snap → settles to nearest
        try { deck.releasePointerCapture(e.pointerId); } catch {}
      };
      deck.addEventListener('pointerup', endDrag);
      deck.addEventListener('pointercancel', endDrag);
      // Suppress the click that would otherwise fire at the end of a drag.
      deck.addEventListener('click', (e: MouseEvent) => {
        if (moved) { e.preventDefault(); e.stopPropagation(); }
      }, true);

      let raf = 0;
      deck.addEventListener('scroll', () => {
        if (raf) return;
        raf = window.requestAnimationFrame(() => { raf = 0; sync(); });
      }, { passive: true });
      window.addEventListener('resize', sync);

      root.classList.add('is-ready');
      sync(); // starts at the first card
    }
  }
</script>
