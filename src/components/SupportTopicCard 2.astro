---
// Support topic card (gold icon + title + description + arrow). The whole
// card is a link to a real destination (catalog, valuation, FAQ, contacto).
import Icon from './Icon.astro';
import type { SupportTopic } from '../data/faqs';

interface Props {
  topic: SupportTopic;
  index?: number;
}
const { topic: t, index = 0 } = Astro.props;
const internal = t.href.startsWith('/') || t.href.startsWith('#');
---
<a
  class="stopic"
  href={t.href}
  data-reveal
  style={`--reveal-delay:${index * 60}ms`}
  rel={internal ? undefined : 'noopener'}
  target={internal ? undefined : '_blank'}
>
  <span class="stopic__ic" aria-hidden="true"><Icon name={t.icon} size={22} stroke={1.5} /></span>
  <span class="stopic__body">
    <span class="stopic__title">{t.title}</span>
    <span class="stopic__text">{t.text}</span>
  </span>
  <span class="stopic__arrow" aria-hidden="true"><Icon name="arrow" size={16} stroke={1.8} /></span>
</a>

<style>
  .stopic {
    display: flex; flex-direction: column; align-items: flex-start; height: 100%;
    padding: clamp(22px, 2.2vw, 30px); text-decoration: none; color: var(--ink);
    background: var(--cream-soft); border: 1px solid var(--ink-10); border-radius: var(--radius-lg);
    transition: transform var(--t-med), border-color var(--t-med), box-shadow var(--t-med), background var(--t-med);
  }
  .stopic:hover { transform: translateY(-4px); border-color: var(--hairline-gold-strong); box-shadow: var(--shadow-card); background: var(--cream); }
  .stopic__ic {
    width: 48px; height: 48px; display: grid; place-items: center; border-radius: 50%;
    color: var(--gold-deep); background: rgba(184, 153, 104, 0.1); border: 1px solid var(--hairline-gold);
    transition: background var(--t-fast), color var(--t-fast);
  }
  .stopic:hover .stopic__ic { background: var(--gold); color: var(--navy-ink); border-color: var(--gold); }
  .stopic__body { display: block; flex: 1; }
  .stopic__title { display: block; font-family: var(--font-serif); font-weight: 500; font-size: 20px; color: var(--ink); margin-top: 18px; letter-spacing: -0.01em; }
  .stopic__text { display: block; margin-top: 8px; font-size: 13.5px; line-height: 1.6; color: var(--ink-60); }
  .stopic__arrow {
    margin-top: 18px; color: var(--gold-deep);
    transition: transform var(--t-med);
  }
  .stopic:hover .stopic__arrow { transform: translateX(5px); }
</style>
