---
// Floating customer-support widget — liquid-glass navy/gold aesthetic,
// matching the chat-pin reference. Site-wide (mounted in Base.astro).
// Channels use the central placeholder contacts from site.ts.
import { site } from '../data/site';
import Icon from './Icon.astro';

const channels = [
  {
    icon: 'whatsapp',
    label: 'WhatsApp',
    desc: 'Resposta rápida, no seu ritmo',
    href: site.whatsappHref,
    external: true,
  },
  {
    icon: 'phone',
    label: 'Telefone',
    desc: site.phone,
    href: site.phoneHref,
    external: false,
  },
  {
    icon: 'mail',
    label: 'E-mail',
    desc: site.email,
    href: `mailto:${site.email}`,
    external: false,
  },
  {
    icon: 'chat',
    label: 'Deixar mensagem',
    desc: 'Falamos consigo com discrição',
    href: '/contacto',
    external: false,
  },
];
---
<div class="cs" data-cs>
  <!-- Panel -->
  <div class="cs__panel" id="cs-panel" role="dialog" aria-label="Apoio ao cliente" aria-modal="false" hidden>
    <header class="cs__head">
      <span class="cs__avatar" aria-hidden="true">
        <Icon name="chat" size={22} stroke={1.5} />
      </span>
      <span class="cs__head-text">
        <span class="cs__title">Apoio Collection Vintage</span>
        <span class="cs__status"><span class="cs__dot" aria-hidden="true"></span> Disponível · sem compromisso</span>
      </span>
      <button class="cs__close" type="button" aria-label="Fechar apoio" data-cs-close>
        <Icon name="close" size={18} stroke={1.7} />
      </button>
    </header>

    <p class="cs__lead">Como prefere falar connosco?</p>

    <ul class="cs__channels">
      {channels.map((c) => (
        <li>
          <a
            class="cs__channel"
            href={c.href}
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener noreferrer' : undefined}
          >
            <span class="cs__channel-ic"><Icon name={c.icon} size={19} stroke={1.6} /></span>
            <span class="cs__channel-text">
              <span class="cs__channel-label">{c.label}</span>
              <span class="cs__channel-desc">{c.desc}</span>
            </span>
            <span class="cs__channel-arrow"><Icon name="arrow" size={16} stroke={1.6} /></span>
          </a>
        </li>
      ))}
    </ul>

    <p class="cs__foot"><Icon name="shield-check" size={14} stroke={1.6} /> Confidencial em cada etapa</p>
  </div>

  <!-- Floating button -->
  <button class="cs__fab" type="button" aria-label="Apoio ao cliente" aria-expanded="false" aria-controls="cs-panel" data-cs-toggle>
    <span class="cs__fab-ring" aria-hidden="true"></span>
    <span class="cs__fab-icon cs__fab-icon--chat" aria-hidden="true"><Icon name="chat" size={26} stroke={1.5} /></span>
    <span class="cs__fab-icon cs__fab-icon--close" aria-hidden="true"><Icon name="close" size={24} stroke={1.8} /></span>
  </button>
</div>

<style>
  .cs {
    position: fixed; right: clamp(16px, 2.4vw, 30px); bottom: clamp(16px, 2.4vw, 30px);
    z-index: 950; display: flex; flex-direction: column; align-items: flex-end; gap: 14px;
  }

  /* ---------- Floating button (liquid-glass navy + gold ring) ---------- */
  .cs__fab {
    position: relative; width: 62px; height: 62px; border-radius: 50%;
    display: grid; place-items: center; cursor: pointer;
    background: radial-gradient(120% 120% at 30% 22%, rgba(26, 54, 86, 0.96), rgba(11, 26, 46, 0.96));
    border: 1px solid rgba(176, 198, 230, 0.22);
    box-shadow:
      0 18px 40px -16px rgba(6, 13, 26, 0.8),
      0 4px 14px -6px rgba(6, 13, 26, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 0 18px -8px rgba(150, 185, 235, 0.4);
    color: var(--gold-light);
    transition: transform var(--t-fast), box-shadow var(--t-fast), border-color var(--t-fast);
  }
  .cs__fab:hover { transform: translateY(-2px); border-color: var(--hairline-gold-strong); }
  .cs__fab:active { transform: translateY(0); }

  /* Gold rim that reads as the pin's bezel */
  .cs__fab-ring {
    position: absolute; inset: 4px; border-radius: 50%; pointer-events: none;
    border: 1px solid rgba(184, 153, 104, 0.55);
    box-shadow: inset 0 0 10px -4px rgba(212, 187, 133, 0.6);
  }

  .cs__fab-icon { position: absolute; line-height: 0; transition: opacity var(--t-fast), transform var(--t-fast); }
  .cs__fab-icon--close { opacity: 0; transform: scale(0.7) rotate(-30deg); }
  .cs[data-open] .cs__fab-icon--chat { opacity: 0; transform: scale(0.7) rotate(30deg); }
  .cs[data-open] .cs__fab-icon--close { opacity: 1; transform: scale(1) rotate(0); color: var(--cream); }

  /* Gentle attention pulse on the rim — disabled for reduced motion */
  .cs__fab::after {
    content: ""; position: absolute; inset: 0; border-radius: 50%; pointer-events: none;
    border: 1px solid rgba(212, 187, 133, 0.5);
    animation: cs-pulse 2.8s ease-out infinite;
  }
  .cs[data-open] .cs__fab::after { animation: none; opacity: 0; }
  @keyframes cs-pulse {
    0% { transform: scale(1); opacity: 0.6; }
    70% { transform: scale(1.45); opacity: 0; }
    100% { transform: scale(1.45); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cs__fab::after { animation: none; opacity: 0; }
  }

  /* ---------- Panel (liquid-glass card) ---------- */
  .cs__panel {
    width: min(340px, calc(100vw - 32px));
    background: linear-gradient(180deg, rgba(16, 36, 61, 0.9), rgba(10, 23, 41, 0.88));
    -webkit-backdrop-filter: blur(22px) saturate(150%); backdrop-filter: blur(22px) saturate(150%);
    border: 1px solid rgba(176, 198, 230, 0.22);
    border-radius: 22px;
    box-shadow:
      0 34px 80px -30px rgba(6, 13, 26, 0.88),
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      inset 0 0 28px -12px rgba(150, 185, 235, 0.3);
    padding: 16px;
    transform-origin: bottom right; transform: translateY(10px) scale(0.96); opacity: 0;
    transition: transform var(--t-med), opacity var(--t-med);
  }
  .cs__panel[hidden] { display: none; }
  .cs[data-open] .cs__panel { transform: translateY(0) scale(1); opacity: 1; }

  .cs__head { display: flex; align-items: center; gap: 12px; }
  .cs__avatar {
    width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0;
    display: grid; place-items: center; color: var(--navy-ink);
    background: linear-gradient(160deg, var(--gold-light), var(--gold-deep));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
  }
  .cs__head-text { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .cs__title {
    font-family: var(--font-serif); font-weight: 500; font-size: 16px; color: var(--cream);
    line-height: 1.1;
  }
  .cs__status { display: inline-flex; align-items: center; gap: 6px; font-size: 11.5px; color: var(--white-70); letter-spacing: 0.02em; }
  .cs__dot { width: 7px; height: 7px; border-radius: 50%; background: #6FCF97; box-shadow: 0 0 7px rgba(111, 207, 151, 0.8); }
  .cs__close {
    margin-left: auto; flex-shrink: 0; width: 30px; height: 30px; border-radius: 50%;
    display: grid; place-items: center; cursor: pointer; color: var(--white-70);
    background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(176, 198, 230, 0.18);
    transition: color var(--t-fast), background var(--t-fast);
  }
  .cs__close:hover { color: var(--cream); background: rgba(255, 255, 255, 0.1); }

  .cs__lead { margin: 16px 2px 12px; font-size: 13px; color: var(--white-70); }

  .cs__channels { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .cs__channel {
    display: flex; align-items: center; gap: 12px; text-decoration: none;
    padding: 11px 12px; border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(176, 198, 230, 0.14);
    transition: background var(--t-fast), border-color var(--t-fast), transform var(--t-fast);
  }
  .cs__channel:hover {
    background: rgba(184, 153, 104, 0.12);
    border-color: var(--hairline-gold-strong);
    transform: translateX(2px);
  }
  .cs__channel-ic {
    width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
    display: grid; place-items: center; color: var(--gold-light);
    background: rgba(11, 26, 46, 0.5); border: 1px solid var(--hairline-gold);
  }
  .cs__channel-text { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .cs__channel-label { font-size: 13.5px; font-weight: 500; color: var(--cream); }
  .cs__channel-desc { font-size: 12px; color: var(--white-50); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .cs__channel-arrow { margin-left: auto; color: var(--white-30); transition: color var(--t-fast), transform var(--t-fast); }
  .cs__channel:hover .cs__channel-arrow { color: var(--gold-light); transform: translateX(2px); }

  .cs__foot {
    margin: 14px 2px 2px; display: flex; align-items: center; justify-content: center; gap: 7px;
    font-size: 11.5px; letter-spacing: 0.02em; color: var(--white-50);
  }
  .cs__foot :global(.icon) { color: var(--gold); }
</style>

<script>
  const root = document.querySelector('[data-cs]') as HTMLElement | null;
  if (root) {
    const toggle = root.querySelector('[data-cs-toggle]') as HTMLButtonElement | null;
    const closeBtn = root.querySelector('[data-cs-close]') as HTMLButtonElement | null;
    const panel = root.querySelector('#cs-panel') as HTMLElement | null;

    const open = () => {
      root.setAttribute('data-open', '');
      toggle?.setAttribute('aria-expanded', 'true');
      toggle?.setAttribute('aria-label', 'Fechar apoio');
      if (panel) panel.hidden = false;
    };
    const close = () => {
      root.removeAttribute('data-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Apoio ao cliente');
      if (panel) panel.hidden = true;
    };

    toggle?.addEventListener('click', () =>
      root.hasAttribute('data-open') ? close() : open()
    );
    closeBtn?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => e.key === 'Escape' && close());
    document.addEventListener('click', (e) => {
      if (root.hasAttribute('data-open') && !root.contains(e.target as Node)) close();
    });
  }
</script>
