---
import SectionEyebrow from './SectionEyebrow.astro';
import Button from './Button.astro';
import Icon from './Icon.astro';
import { careersProcess as p } from '../data/carreiras';
---
<section class="section section--cream cprocess">
  <div class="container">
    <header class="shead shead--center">
      <SectionEyebrow text={p.eyebrow} center />
      <h2 class="h2 cprocess__title" data-reveal style="--reveal-delay:80ms">
        {p.titleLead} <em class="em-gold serif-it">{p.titleEmphasis}</em>
      </h2>
      <p class="lede cprocess__lede" data-reveal style="--reveal-delay:150ms">{p.text}</p>
    </header>

    <ol class="cproc" data-reveal>
      <span class="cproc__line" aria-hidden="true"></span>
      {p.steps.map((s, i) => (
        <li class="cproc__step" style={`--d:${i * 150}ms`}>
          <span class="cproc__icon"><Icon name={s.icon} size={24} stroke={1.4} /></span>
          <div class="cproc__body">
            <span class="cproc__num">{s.num}</span>
            <h3 class="cproc__name">{s.name}</h3>
            <p class="cproc__text">{s.text}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="cprocess__cta" data-reveal>
      <Button href={p.cta.href} variant="gold" arrow>{p.cta.label}</Button>
    </div>
  </div>
</section>

<style>
  .shead { margin-bottom: clamp(40px, 5vw, 68px); }
  .shead--center { text-align: center; }
  .cprocess__title { margin-top: 16px; margin-inline: auto; }
  .cprocess__lede { margin: 16px auto 0; }

  .cproc {
    position: relative; list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(5, 1fr); gap: clamp(16px, 2vw, 30px);
  }
  .cproc__line {
    position: absolute; top: 27px; left: 10%; right: 10%; height: 1px;
    background: linear-gradient(to right, var(--hairline-gold-strong), var(--gold), var(--hairline-gold-strong));
    transform: scaleX(0); transform-origin: left; transition: transform 1300ms var(--t-ease-emph);
  }
  .cproc.is-in .cproc__line { transform: scaleX(1); }
  .cproc__step {
    position: relative; display: flex; flex-direction: column; align-items: center; text-align: center;
    opacity: 0; transform: translateY(16px); transition: opacity var(--t-slow), transform var(--t-slow); transition-delay: var(--d);
  }
  .cproc.is-in .cproc__step { opacity: 1; transform: none; }
  .cproc__icon {
    width: 54px; height: 54px; border-radius: 50%; display: grid; place-items: center; position: relative; z-index: 1;
    background: var(--cream); border: 1px solid var(--hairline-gold-strong); color: var(--gold-deep);
    transition: background var(--t-med), color var(--t-med), transform var(--t-med), box-shadow var(--t-med);
  }
  .cproc__step:hover .cproc__icon {
    background: var(--gold); color: var(--navy-ink); transform: translateY(-3px);
    box-shadow: 0 0 0 6px rgba(184, 153, 104, 0.14);
  }
  .cproc__num { font-family: var(--font-serif); font-size: 14px; letter-spacing: 0.1em; color: var(--gold-deep); }
  .cproc__name { font-family: var(--font-serif); font-weight: 500; font-size: 20px; margin: 4px 0 0; letter-spacing: -0.01em; }
  .cproc__body { margin-top: 18px; }
  .cproc__text { margin: 10px 0 0; font-size: 13.5px; line-height: 1.55; color: var(--ink-60); }

  .cprocess__cta { margin-top: clamp(44px, 5vw, 72px); text-align: center; }

  @media (max-width: 760px) {
    .cproc { grid-template-columns: 1fr; gap: 0; }
    .cproc__line { top: 26px; bottom: 26px; left: 26px; right: auto; width: 1px; height: auto; transform: scaleY(0); transform-origin: top; }
    .cproc.is-in .cproc__line { transform: scaleY(1); }
    .cproc__step { flex-direction: row; align-items: flex-start; text-align: left; gap: 18px; padding: 14px 0; transform: translateX(14px); }
    .cproc.is-in .cproc__step { transform: none; }
    .cproc__icon { width: 52px; height: 52px; flex-shrink: 0; }
    .cproc__body { margin-top: 0; padding-top: 4px; }
  }
</style>
