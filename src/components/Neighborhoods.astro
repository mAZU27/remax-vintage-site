---
// Zonas — self-contained premium section.
// Centered header + interactive SVG Porto map (glowing numbered pins + floating
// tooltip) framed by four glass neighbourhood cards, plus an honest stats bar.
// Data-driven from `neighborhoods` / `zonasStats` in site.ts.
// Interaction (hover/focus/keyboard sync, tooltip, count-up) lives in the
// <script> below; all motion is guarded by prefers-reduced-motion.
import { neighborhoods, zonasStats } from '../data/site';
import Icon from './Icon.astro';
import Button from './Button.astro';
import SectionEyebrow from './SectionEyebrow.astro';
---
<section class="zonas section section--navy on-navy" id="zonas" data-zonas>
  <div class="zonas__glow zonas__glow--a" aria-hidden="true"></div>
  <div class="zonas__glow zonas__glow--b" aria-hidden="true"></div>
  <div class="zonas__grain" aria-hidden="true"></div>

  <div class="container zonas__inner">
    <header class="zonas__head">
      <SectionEyebrow text="Zonas" center />
      <h2 class="h2 zonas__title" data-reveal style="--reveal-delay:80ms">
        Zonas. Cada história<br /><em class="em-gold serif-it">tem o seu valor.</em>
      </h2>
      <p class="lede zonas__sub" data-reveal style="--reveal-delay:160ms">
        Explore as zonas mais exclusivas do Porto. Escolha uma zona no mapa e descubra
        o seu carácter, estilo de vida e oportunidades únicas.
      </p>
    </header>

    <div class="zonas__stage">
      {neighborhoods.map((n, i) => (
        <article
          class="bcard"
          data-slug={n.slug}
          data-reveal
          style={`grid-area: card${n.num}; --reveal-delay:${260 + i * 90}ms`}
        >
          <div class="bcard__top">
            <span class="bcard__num">{n.num}</span>
            <span class="bcard__glyph"><Icon name={n.glyph} size={26} stroke={1.4} /></span>
          </div>
          <h3 class="bcard__name">{n.name}</h3>
          <span class="bcard__ctx">{n.context}</span>
          <p class="bcard__blurb">{n.blurb}</p>
          <ul class="bcard__features">
            {n.features.map((f) => (
              <li><Icon name={f.icon} size={14} stroke={1.5} /> {f.label}</li>
            ))}
          </ul>
          <a class="bcard__link" href={`/imoveis?zona=${n.slug}`}>
            Explorar zona <Icon name="arrow" size={14} stroke={1.8} />
          </a>
        </article>
      ))}

      <div class="zonas__mapcol" style="grid-area: map">
        <div class="zonas__mapcta">
          <Button href="/imoveis" variant="gold" arrow>Ver toda a coleção</Button>
        </div>

        <div class="zonas__mapwrap" data-reveal style="--reveal-delay:200ms">
          <svg class="zonas__map" viewBox="0 0 1000 640" fill="none" aria-hidden="true">
            <g class="zonas__districts">
              <path class="district" pathLength="1" d="M360 132 L556 112 L650 210 L556 332 L408 350 L320 250 Z" />
              <path class="district" pathLength="1" d="M556 112 L800 122 L862 252 L700 322 L650 210 Z" />
              <path class="district" pathLength="1" d="M150 282 L320 250 L408 350 L330 470 L182 442 Z" />
              <path class="district" pathLength="1" d="M408 350 L556 332 L650 432 L600 540 L444 540 L330 470 Z" />
            </g>
            <g class="zonas__avenues">
              <path class="avenue" d="M320 250 L650 432" />
              <path class="avenue" d="M556 112 L556 332" />
              <path class="avenue" d="M150 282 L862 252" />
            </g>
            <path class="water" d="M0 640 L0 384 Q140 404 262 472 Q420 560 642 558 Q840 556 1000 510 L1000 640 Z" />
          </svg>

          <div class="zonas__pins">
            {neighborhoods.map((n, i) => (
              <button
                type="button"
                class="pin"
                data-slug={n.slug}
                data-x={n.x}
                data-y={n.y}
                data-name={n.name}
                data-price={n.price}
                data-demand={n.demand}
                data-href={`/imoveis?zona=${n.slug}`}
                style={`left:${n.x}%; top:${n.y}%; --pin-delay:${i * 150}ms`}
                aria-label={`Ver zona ${n.name}`}
              >
                <span class="pin__pulse" aria-hidden="true"></span>
                <span class="pin__dot"><span class="pin__num">{n.num}</span></span>
              </button>
            ))}

            <div class="zonas__tip" data-tip role="status" aria-live="polite">
              <span class="zonas__tip-name" data-tip-name></span>
              <dl class="zonas__tip-meta">
                <div><dt>Preço médio</dt><dd data-tip-price></dd></div>
                <div><dt>Procura</dt><dd data-tip-demand></dd></div>
              </dl>
              <a class="zonas__tip-link" data-tip-link href="/imoveis">
                Ver imóveis <Icon name="arrow" size={13} stroke={1.8} />
              </a>
            </div>
          </div>
        </div>

        <span class="zonas__cue" aria-hidden="true">
          <Icon name="chevron" size={15} stroke={1.6} />
          Passe sobre uma zona para explorar
        </span>
      </div>
    </div>

    <div class="zonas__stats" data-zonas-stats data-reveal>
      {zonasStats.map((s) => (
        <div class="bstat">
          <span class="bstat__icon"><Icon name={s.icon} size={20} stroke={1.5} /></span>
          <span class="bstat__value" data-count-to={'countTo' in s ? s.countTo : ''}>{s.value}</span>
          <span class="bstat__label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .zonas { position: relative; isolation: isolate; overflow: hidden; }
  .zonas__inner { position: relative; z-index: 1; }

  /* Ambient light */
  .zonas__glow { position: absolute; border-radius: 50%; filter: blur(90px); pointer-events: none; z-index: 0; }
  .zonas__glow--a {
    width: 540px; height: 540px; top: -140px; left: 50%; transform: translateX(-50%);
    background: radial-gradient(circle, rgba(184, 153, 104, 0.16), transparent 70%);
  }
  .zonas__glow--b {
    width: 620px; height: 620px; bottom: -220px; left: -120px;
    background: radial-gradient(circle, rgba(26, 54, 86, 0.55), transparent 70%);
  }
  .zonas__grain {
    position: absolute; inset: 0; z-index: 0; opacity: 0.4; mix-blend-mode: overlay; pointer-events: none;
    background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.1) 1px, transparent 0);
    background-size: 3px 3px;
  }

  /* Header */
  .zonas__head { text-align: center; max-width: 760px; margin: 0 auto; }
  .zonas__title { margin-top: 18px; margin-inline: auto; }
  .zonas__sub { margin: 18px auto 0; max-width: 60ch; }

  /* Stage: cards in the four corners, map spanning the centre column */
  .zonas__stage {
    margin-top: clamp(40px, 5vw, 66px);
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(360px, 1.55fr) minmax(220px, 1fr);
    grid-template-rows: auto auto;
    grid-template-areas:
      "cardI   map cardII"
      "cardIII map cardIV";
    gap: clamp(16px, 1.8vw, 26px);
    align-items: stretch;
  }

  /* Map column */
  .zonas__mapcol { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: clamp(14px, 1.6vw, 22px); }
  .zonas__mapwrap { position: relative; width: 100%; }
  .zonas__map { width: 100%; height: auto; display: block; overflow: visible; }

  .district {
    fill: var(--gold); fill-opacity: 0.05; stroke: var(--gold); stroke-width: 1.4;
    stroke-dasharray: 1; stroke-dashoffset: 1;
    transition: stroke-dashoffset 1.3s var(--t-ease-emph);
  }
  .zonas__mapwrap.is-in .district { stroke-dashoffset: 0; }
  .district:nth-child(1) { transition-delay: 0.05s; }
  .district:nth-child(2) { transition-delay: 0.2s; }
  .district:nth-child(3) { transition-delay: 0.35s; }
  .district:nth-child(4) { transition-delay: 0.5s; }

  .avenue { fill: none; stroke: var(--gold-light); stroke-width: 1; stroke-dasharray: 2 8; stroke-linecap: round; opacity: 0; transition: opacity 0.9s ease 0.7s; }
  .zonas__mapwrap.is-in .avenue { opacity: 0.24; }

  .water { fill: var(--navy-ink); fill-opacity: 0.55; stroke: var(--hairline-gold); stroke-width: 1; }

  /* Pins (HTML overlay, positioned in % over the map) */
  .zonas__pins { position: absolute; inset: 0; }
  .pin {
    position: absolute; width: 44px; height: 44px; margin: 0; padding: 0; border: 0; background: none; cursor: pointer;
    transform: translate(-50%, -50%) scale(0.4); opacity: 0;
    transition: opacity 0.55s var(--t-ease-emph), transform 0.55s var(--t-ease-emph);
    transition-delay: calc(620ms + var(--pin-delay, 0ms));
    z-index: 3;
  }
  .zonas__mapwrap.is-in .pin { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  .pin__dot {
    position: absolute; inset: 6px; border-radius: 50%; display: grid; place-items: center;
    background: radial-gradient(circle at 50% 32%, var(--gold-light), var(--gold-deep));
    color: var(--navy-ink); font-family: var(--font-serif); font-weight: 600; font-size: 14px; line-height: 1;
    box-shadow: 0 0 0 1px rgba(244, 237, 222, 0.3), 0 0 16px rgba(212, 187, 133, 0.45), 0 6px 14px rgba(0, 0, 0, 0.4);
    transition: transform var(--t-med), box-shadow var(--t-med);
  }
  .pin:hover .pin__dot, .pin:focus-visible .pin__dot { transform: scale(1.08); }
  .pin.is-active .pin__dot {
    transform: scale(1.16);
    box-shadow: 0 0 0 1px rgba(244, 237, 222, 0.5), 0 0 28px rgba(212, 187, 133, 0.85), 0 8px 22px rgba(0, 0, 0, 0.5);
  }
  .pin:focus-visible { outline: none; }
  .pin:focus-visible .pin__dot { box-shadow: 0 0 0 3px rgba(184, 153, 104, 0.6), 0 0 18px rgba(212, 187, 133, 0.55); }
  .pin__pulse {
    position: absolute; inset: 6px; border-radius: 50%; border: 1px solid var(--gold-light); opacity: 0; pointer-events: none;
  }
  .pin.is-active .pin__pulse { animation: pinPulse 2.2s ease-out infinite; }
  @keyframes pinPulse {
    0% { opacity: 0.55; transform: scale(1); }
    100% { opacity: 0; transform: scale(2.5); }
  }

  /* Floating tooltip */
  .zonas__tip {
    position: absolute; left: 50%; top: 50%; transform: translate(-50%, calc(-100% - 22px));
    width: max-content; min-width: 208px; max-width: 244px; text-align: left;
    background: rgba(11, 26, 46, 0.92);
    -webkit-backdrop-filter: blur(12px) saturate(140%); backdrop-filter: blur(12px) saturate(140%);
    border: 1px solid var(--hairline-gold-strong); border-radius: var(--radius);
    padding: 15px 17px; box-shadow: var(--shadow-float);
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity var(--t-med), transform var(--t-med), visibility var(--t-med);
    z-index: 6;
  }
  .zonas__tip.is-on { opacity: 1; visibility: visible; pointer-events: auto; transform: translate(-50%, calc(-100% - 16px)); }
  .zonas__tip::after {
    content: ''; position: absolute; left: 50%; bottom: -6px; width: 11px; height: 11px;
    transform: translateX(-50%) rotate(45deg);
    background: rgba(11, 26, 46, 0.92);
    border-right: 1px solid var(--hairline-gold-strong); border-bottom: 1px solid var(--hairline-gold-strong);
  }
  .zonas__tip-name {
    display: block; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold-light); font-weight: 600;
  }
  .zonas__tip-meta { margin: 12px 0 0; display: flex; flex-direction: column; gap: 8px; }
  .zonas__tip-meta div { display: flex; align-items: baseline; justify-content: space-between; gap: 14px; }
  .zonas__tip-meta dt { font-size: 11px; color: var(--white-50); letter-spacing: 0.04em; }
  .zonas__tip-meta dd { margin: 0; font-size: 13px; color: var(--cream); font-weight: 500; }
  .zonas__tip-link {
    display: inline-flex; align-items: center; gap: 7px; margin-top: 14px; padding-top: 12px;
    border-top: 1px solid var(--hairline-light);
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold-light);
    text-decoration: none; font-weight: 500;
  }
  .zonas__tip-link :global(.arrow) { transition: transform var(--t-fast); }
  .zonas__tip-link:hover :global(.arrow) { transform: translateX(4px); }

  /* Scroll/explore cue */
  .zonas__cue {
    display: inline-flex; align-items: center; gap: 8px; color: var(--white-50);
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
  }
  .zonas__cue :global(.icon) { color: var(--gold-light); }

  /* Cards */
  .bcard {
    position: relative; display: flex; flex-direction: column;
    padding: clamp(20px, 1.7vw, 26px);
    background: rgba(16, 39, 66, 0.45);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
    border: 1px solid var(--hairline-light); border-radius: var(--radius-lg);
    transition: transform var(--t-med), border-color var(--t-med), box-shadow var(--t-med), background var(--t-med), opacity var(--t-med);
  }
  .zonas .bcard:hover, .zonas .bcard.is-active {
    transform: translateY(-4px); border-color: var(--hairline-gold-strong);
    box-shadow: var(--shadow-float); background: rgba(16, 39, 66, 0.62);
  }
  .bcard__top { display: flex; align-items: center; justify-content: space-between; }
  .bcard__num { font-family: var(--font-serif); font-size: 26px; color: var(--gold-light); line-height: 1; }
  .bcard__glyph { color: var(--gold-light); opacity: 0.85; display: inline-flex; }
  .bcard__name { font-family: var(--font-serif); font-weight: 500; font-size: 23px; line-height: 1.1; margin-top: 14px; color: var(--cream); }
  .bcard__ctx { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-top: 5px; }
  .bcard__blurb { font-size: 13px; line-height: 1.6; color: var(--white-70); margin-top: 12px; }
  .bcard__features { list-style: none; margin: 15px 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: 7px; }
  .bcard__features li {
    display: inline-flex; align-items: center; gap: 6px; font-size: 11px; color: var(--white-90);
    padding: 5px 10px; border: 1px solid var(--hairline-light); border-radius: 999px;
  }
  .bcard__features :global(.icon) { color: var(--gold-light); }
  .bcard__link {
    margin-top: auto; padding-top: 18px; display: inline-flex; align-items: center; gap: 8px;
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold-light);
    text-decoration: none; font-weight: 500;
  }
  .bcard__link :global(.arrow) { transition: transform var(--t-fast); }
  .bcard__link:hover :global(.arrow) { transform: translateX(4px); }

  /* Stats bar */
  .zonas__stats {
    margin-top: clamp(48px, 6vw, 82px);
    display: grid; grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--hairline-gold); border-radius: var(--radius-lg);
    background: rgba(16, 39, 66, 0.4); overflow: hidden;
  }
  .bstat {
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 9px;
    padding: clamp(22px, 2.4vw, 32px) 18px; border-left: 1px solid var(--hairline-light);
  }
  .bstat:first-child { border-left: 0; }
  .bstat__icon { color: var(--gold-light); display: inline-flex; }
  .bstat__value { font-family: var(--font-serif); font-weight: 500; font-size: clamp(26px, 3vw, 38px); color: var(--cream); line-height: 1; }
  .bstat__label { font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--white-70); max-width: 18ch; }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .zonas__stage {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "map   map"
        "cardI cardII"
        "cardIII cardIV";
    }
    .zonas__mapwrap { max-width: 620px; margin-inline: auto; }
  }
  @media (max-width: 560px) {
    /* Mobile: mapa no topo, depois 4 cards horizontais */
    .zonas__stage {
      grid-template-columns: 1fr;
      grid-template-areas: "map" "cardI" "cardII" "cardIII" "cardIV";
      gap: clamp(14px, 2.2vw, 18px);
    }

    /* Cards: layout HORIZONTAL - conteúdo à esquerda, imagem à direita */
    .bcard {
      position: relative;
      display: grid;
      grid-template-columns: 1fr clamp(100px, 24vw, 118px);
      gap: clamp(12px, 1.8vw, 16px);
      padding: clamp(14px, 2vw, 18px);
      align-items: start;
      min-height: auto;
    }

    /* Número romano - overlay no topo esquerdo */
    .bcard__top {
      position: absolute;
      top: clamp(10px, 1.3vw, 12px);
      left: clamp(13px, 1.5vw, 15px);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      z-index: 2;
    }
    .bcard__num {
      font-size: clamp(22px, 3.2vw, 28px);
      color: var(--gold-light);
      line-height: 0.95;
      font-weight: 600;
    }
    .bcard__glyph {
      display: none;
    }

    /* Imagem placeholder à direita */
    .bcard::before {
      content: '';
      grid-column: 2;
      grid-row: 1 / -1;
      border-radius: var(--radius-lg);
      background: linear-gradient(135deg, rgba(212, 187, 133, 0.12), rgba(212, 187, 133, 0.05));
      border: 1px solid var(--hairline-gold);
      z-index: 1;
    }

    /* Conteúdo à esquerda em coluna - com padding para não sobrepor número */
    .bcard > div:not(.bcard__top):not(.bcard__link) {
      grid-column: 1;
      display: flex;
      flex-direction: column;
      z-index: 2;
      padding-top: clamp(28px, 6vw, 32px);
      padding-right: clamp(6px, 1vw, 10px);
    }

    .bcard__name {
      font-size: clamp(15px, 2.1vw, 19px);
      margin: 0 0 clamp(4px, 0.8vw, 6px) 0;
      color: var(--cream);
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.005em;
    }
    .bcard__ctx {
      font-size: clamp(7px, 0.9vw, 8px);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold-light);
      margin: 0 0 clamp(6px, 1.2vw, 8px) 0;
      font-weight: 500;
    }
    .bcard__blurb {
      font-size: clamp(11px, 1.1vw, 13px);
      line-height: 1.5;
      color: var(--white-70);
      margin: 0 0 clamp(8px, 1.4vw, 10px) 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      letter-spacing: 0.01em;
    }
    .bcard__features {
      gap: clamp(5px, 1vw, 7px);
      margin: 0;
      display: flex;
      flex-wrap: wrap;
    }
    .bcard__features li {
      font-size: clamp(8px, 1vw, 9px);
      padding: clamp(4px, 0.8vw, 6px) clamp(8px, 1.2vw, 10px);
      gap: clamp(3px, 0.6vw, 5px);
    }
    .bcard__link {
      display: none;
    }

    .zonas__stats { grid-template-columns: repeat(2, 1fr); }
    .bstat:nth-child(odd) { border-left: 0; }
    .bstat:nth-child(even) { border-left: 1px solid var(--hairline-light); }
    .bstat:nth-child(n + 3) { border-top: 1px solid var(--hairline-light); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pin { opacity: 1 !important; transform: translate(-50%, -50%) !important; transition: none; }
    .pin.is-active .pin__pulse { animation: none; }
    .district { stroke-dashoffset: 0 !important; transition: none; }
    .avenue { opacity: 0.24; transition: none; }
    .zonas__tip { transition: opacity var(--t-fast); }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-zonas]');
  if (root) {
    const pins = Array.from(root.querySelectorAll<HTMLButtonElement>('.pin'));
    const cards = Array.from(root.querySelectorAll<HTMLElement>('.bcard'));
    const tip = root.querySelector<HTMLElement>('[data-tip]');
    const tipName = root.querySelector<HTMLElement>('[data-tip-name]');
    const tipPrice = root.querySelector<HTMLElement>('[data-tip-price]');
    const tipDemand = root.querySelector<HTMLElement>('[data-tip-demand]');
    const tipLink = root.querySelector<HTMLAnchorElement>('[data-tip-link]');

    const setActive = (slug: string | undefined) => {
      if (!slug) return;
      const pin = pins.find((p) => p.dataset.slug === slug);
      if (!pin) return;
      pins.forEach((p) => p.classList.toggle('is-active', p === pin));
      cards.forEach((c) => c.classList.toggle('is-active', c.dataset.slug === slug));
      if (tip) {
        tip.style.left = `${pin.dataset.x}%`;
        tip.style.top = `${pin.dataset.y}%`;
        if (tipName) tipName.textContent = pin.dataset.name ?? '';
        if (tipPrice) tipPrice.textContent = pin.dataset.price ?? '';
        if (tipDemand) tipDemand.textContent = pin.dataset.demand ?? '';
        if (tipLink && pin.dataset.href) tipLink.setAttribute('href', pin.dataset.href);
        tip.classList.add('is-on');
      }
    };

    pins.forEach((p) => {
      p.addEventListener('mouseenter', () => setActive(p.dataset.slug));
      p.addEventListener('focus', () => setActive(p.dataset.slug));
      p.addEventListener('click', () => setActive(p.dataset.slug));
    });
    cards.forEach((c) => {
      c.addEventListener('mouseenter', () => setActive(c.dataset.slug));
      c.addEventListener('focusin', () => setActive(c.dataset.slug));
    });

    // Default active neighbourhood; stays put on mouse-leave (keeps last active).
    setActive('foz-do-douro');

    // Count-up — only on numeric, real values; runs once when the bar is seen.
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const statsEl = root.querySelector<HTMLElement>('[data-zonas-stats]');
    const counters = Array.from(root.querySelectorAll<HTMLElement>('[data-count-to]')).filter(
      (el) => el.dataset.countTo,
    );
    const runCount = () => {
      counters.forEach((el) => {
        const target = parseInt(el.dataset.countTo ?? '', 10);
        if (Number.isNaN(target)) return;
        if (reduce) {
          el.textContent = String(target);
          return;
        }
        const dur = 1100;
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = String(Math.round(target * eased));
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    };
    if (statsEl && counters.length) {
      if (reduce || !('IntersectionObserver' in window)) {
        runCount();
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                runCount();
                obs.disconnect();
              }
            });
          },
          { threshold: 0.4 },
        );
        io.observe(statsEl);
      }
    }
  }
</script>
