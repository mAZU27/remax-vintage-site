---
// Cinematic brand end-cap — the final, signature moment of every page.
// Full-bleed Porto/Douro dusk panorama under a deep-navy overlay, with the
// "Collection Vintage" wordmark on a single line, a diamond ornament, the
// tagline, and a bottom-left CTA card. Reveal is orchestrated from `.fb`:
// the global IntersectionObserver adds `.is-in`, children cascade via `--d`.
import Icon from './Icon.astro';
import Crest from './Crest.astro';
import { primaryCta } from '../data/site';
---
<section class="fb" data-reveal>
  <!-- Background: Porto / Douro at dusk + deep-navy overlay -->
  <div class="fb__bg" aria-hidden="true">
    <img
      src="/images/porto/porto-douro-poente-1920.webp"
      srcset="/images/porto/porto-douro-poente-1280.webp 1280w, /images/porto/porto-douro-poente-1920.webp 1920w, /images/porto/porto-douro-poente-2560.webp 2560w"
      sizes="100vw"
      alt=""
      width="1920"
      height="1081"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="fb__overlay" aria-hidden="true"></div>
  <div class="fb__glow" aria-hidden="true"></div>

  <div class="container fb__inner">
    <div class="fb__eyebrow r" style="--d: 120ms">
      <span class="fb__place fb__place--l">Porto</span>
      <Crest size={44} />
      <span class="fb__place fb__place--r">Portugal</span>
    </div>

    <h2 class="fb__title r" style="--d: 240ms">Collection Vintage</h2>

    <span class="fb__ornament r" style="--d: 380ms" aria-hidden="true"></span>

    <p class="fb__tagline r" style="--d: 480ms">
      Propriedades exclusivas <span aria-hidden="true">·</span> Valores intemporais
    </p>
  </div>

  <!-- CTA card — bottom-left -->
  <div class="fb__cta-wrap r" style="--d: 620ms">
    <a class="fb__cta" href={primaryCta.href} aria-label={`${primaryCta.label} — o próximo passo`}>
      <span class="fb__cta-ic" aria-hidden="true"><Icon name="building" size={26} stroke={1.4} /></span>
      <span class="fb__cta-text">
        <span class="fb__cta-label">Pronto para o próximo passo?</span>
        <span class="fb__cta-title">{primaryCta.label}</span>
      </span>
      <span class="fb__cta-arrow" aria-hidden="true"><Icon name="arrow" size={20} stroke={1.8} /></span>
    </a>
  </div>
</section>

<style>
  .fb {
    position: relative; isolation: isolate; overflow: hidden;
    min-height: min(100svh, 940px);
    display: flex; align-items: center; justify-content: center;
    padding: clamp(96px, 12vw, 150px) var(--gutter) clamp(120px, 16vw, 200px);
    background: var(--navy-ink); color: var(--cream);
    /* Subtle hairline separating the section from what precedes it. */
    border-top: 1px solid var(--hairline-gold);
  }
  .fb[data-reveal] { transform: none; transition: opacity 1.1s var(--t-ease-emph); }

  /* ---- Background image + overlay ---- */
  .fb__bg { position: absolute; inset: 0; z-index: 0; }
  /* High-res Douro/Ribeira at golden hour. object-position keeps the river +
     Dom Luís skyline behind the centred wordmark; the lit quay sits low-left
     under the CTA card. Mobile shifts the crop to hold the skyline in frame. */
  .fb__bg img { width: 100%; height: 100%; object-fit: cover; object-position: 54% 42%; }
  @media (max-width: 560px) { .fb__bg img { object-position: 62% 44%; } }
  .fb__overlay {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background:
      linear-gradient(180deg, rgba(8, 16, 28, 0.82) 0%, rgba(8, 16, 28, 0.5) 34%, rgba(8, 16, 28, 0.62) 70%, rgba(8, 16, 28, 0.9) 100%),
      radial-gradient(120% 80% at 50% 46%, transparent 38%, rgba(8, 16, 28, 0.5) 100%);
  }
  /* Soft dark halo behind the wordmark — seats the gold lettering over the
     bright golden cityscape so it stays legible (never to hide the image). */
  .fb__glow {
    position: absolute; left: 50%; top: 46%; transform: translate(-50%, -50%);
    width: min(1100px, 92%); height: 62%; z-index: 1; pointer-events: none;
    background: radial-gradient(closest-side, rgba(6, 13, 24, 0.6), transparent 74%);
  }

  /* ---- Reveal cascade ---- */
  .fb__inner { position: relative; z-index: 2; text-align: center; width: 100%; }
  .fb .r {
    opacity: 0; transform: translateY(22px);
    transition: opacity 0.95s var(--t-ease-emph), transform 0.95s var(--t-ease-emph);
    transition-delay: var(--d, 0ms); will-change: opacity, transform;
  }
  .fb.is-in .r { opacity: 1; transform: none; }

  /* ---- Eyebrow: PORTO · VC crest · PORTUGAL ---- */
  .fb__eyebrow { display: inline-flex; align-items: center; justify-content: center; gap: clamp(18px, 3vw, 42px); }
  .fb__place {
    font-family: var(--font-sans); font-size: clamp(11px, 1vw, 13px); letter-spacing: 0.42em;
    text-transform: uppercase; color: var(--gold-light); font-weight: 500;
  }
  .fb__place--l { padding-left: 0.42em; }

  /* ---- Wordmark — single line, soft gold ---- */
  .fb__title {
    margin: clamp(20px, 2.6vw, 40px) 0 0; white-space: nowrap;
    font-family: var(--font-serif); font-weight: 500; line-height: 1;
    font-size: clamp(34px, 8.4vw, 124px); letter-spacing: -0.012em;
    background: linear-gradient(180deg, var(--gold-light) 0%, var(--gold) 56%, var(--gold-deep) 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    filter: drop-shadow(0 6px 26px rgba(0, 0, 0, 0.45));
  }
  @supports not ((-webkit-background-clip: text) or (background-clip: text)) {
    .fb__title { background: none; color: var(--gold-light); }
  }

  /* ---- Diamond ornament ---- */
  .fb__ornament {
    position: relative; display: block; height: 10px;
    width: clamp(120px, 16vw, 230px); margin: clamp(18px, 2vw, 30px) auto 0;
  }
  .fb__ornament::before {
    content: ""; position: absolute; top: 50%; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .fb__ornament::after {
    content: ""; position: absolute; top: 50%; left: 50%; width: 7px; height: 7px;
    transform: translate(-50%, -50%) rotate(45deg);
    background: var(--gold-light); box-shadow: 0 0 9px rgba(212, 187, 133, 0.65);
  }

  /* ---- Tagline ---- */
  .fb__tagline {
    margin: clamp(18px, 2.2vw, 28px) 0 0; font-family: var(--font-sans);
    font-size: clamp(11px, 1.25vw, 15px); letter-spacing: 0.34em; text-transform: uppercase;
    color: var(--gold-light);
  }
  .fb__tagline span { color: var(--gold); margin: 0 0.5em; }

  /* ---- CTA card (bottom-left) ---- */
  .fb__cta-wrap { position: absolute; left: var(--gutter); bottom: clamp(44px, 6vw, 86px); z-index: 3; }
  .fb__cta {
    display: inline-flex; align-items: center; gap: clamp(16px, 1.5vw, 24px);
    padding: clamp(14px, 1.3vw, 20px) clamp(16px, 1.4vw, 22px); border-radius: 20px; text-decoration: none;
    background: rgba(11, 26, 46, 0.5); border: 1px solid var(--hairline-gold);
    -webkit-backdrop-filter: blur(14px) saturate(140%); backdrop-filter: blur(14px) saturate(140%);
    box-shadow:
      0 30px 70px -38px rgba(0, 0, 0, 0.85),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transition: transform var(--t-med), border-color var(--t-med), box-shadow var(--t-med), background var(--t-med);
  }
  .fb__cta:hover {
    transform: translateY(-4px); border-color: var(--gold-light); background: rgba(11, 26, 46, 0.64);
    box-shadow: 0 36px 80px -38px rgba(0, 0, 0, 0.9), 0 0 0 1px rgba(212, 187, 133, 0.22);
  }
  .fb__cta-ic {
    width: clamp(54px, 4.4vw, 66px); height: clamp(54px, 4.4vw, 66px); border-radius: 50%; flex-shrink: 0;
    display: grid; place-items: center; color: var(--gold-light);
    border: 1px solid var(--hairline-gold-strong); background: rgba(11, 26, 46, 0.4);
  }
  .fb__cta-text { display: flex; flex-direction: column; gap: 4px; text-align: left; padding-right: clamp(6px, 1.4vw, 20px); }
  .fb__cta-label { font-size: 10.5px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold-light); }
  .fb__cta-title { font-family: var(--font-serif); font-size: clamp(22px, 2vw, 28px); font-weight: 500; color: var(--cream); line-height: 1; }
  .fb__cta-arrow {
    width: 52px; height: 52px; border-radius: 50%; flex-shrink: 0;
    display: grid; place-items: center; color: var(--gold-light);
    border: 1px solid var(--hairline-gold-strong);
    transition: background var(--t-med), color var(--t-med), border-color var(--t-med);
  }
  .fb__cta-arrow :global(.arrow) { transition: transform var(--t-med); }
  .fb__cta:hover .fb__cta-arrow { background: var(--gold); color: var(--navy-ink); border-color: var(--gold); }
  .fb__cta:hover .fb__cta-arrow :global(.arrow) { transform: translateX(3px); }

  /* ---- Responsive ---- */
  @media (max-width: 1100px) {
    .fb { padding-bottom: clamp(150px, 26vw, 230px); }
    .fb__cta-wrap { left: var(--gutter); right: var(--gutter); text-align: center; }
  }
  @media (max-width: 560px) {
    .fb { min-height: min(92svh, 760px); }
    .fb__cta { width: 100%; max-width: 400px; gap: 14px; }
    .fb__cta-title { font-size: 21px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .fb .r { opacity: 1; transform: none; transition: none; }
  }
</style>
