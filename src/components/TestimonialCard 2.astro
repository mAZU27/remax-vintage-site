---
// Static testimonial card (quote + name + transaction type). Used on
// /sobre-nos. Content comes from data/site.ts `testimonials` (flagged
// placeholders — replace with real, authorised testimonials).
import Icon from './Icon.astro';

interface Props {
  quote: string;
  name: string;
  context: string;
  index?: number;
}
const { quote, name, context, index = 0 } = Astro.props;
---
<figure class="tmt" data-reveal style={`--reveal-delay:${index * 90}ms`}>
  <span class="tmt__mark" aria-hidden="true"><Icon name="quote" size={26} stroke={1.4} /></span>
  <blockquote class="tmt__quote">{quote}</blockquote>
  <figcaption class="tmt__cite">
    <span class="tmt__name">{name}</span>
    <span class="tmt__ctx">{context}</span>
  </figcaption>
</figure>

<style>
  .tmt {
    margin: 0; height: 100%; display: flex; flex-direction: column;
    background: var(--cream); border: 1px solid var(--ink-10); border-radius: var(--radius-lg);
    padding: clamp(26px, 2.4vw, 36px);
    transition: transform var(--t-med), border-color var(--t-med), box-shadow var(--t-med);
  }
  .tmt:hover { transform: translateY(-4px); border-color: var(--hairline-gold-strong); box-shadow: var(--shadow-card); }
  .tmt__mark { color: var(--gold); }
  .tmt__quote {
    margin: 16px 0 0; font-family: var(--font-serif); font-style: italic; font-weight: 400;
    font-size: clamp(18px, 1.5vw, 21px); line-height: 1.5; color: var(--ink); letter-spacing: -0.01em; flex: 1;
  }
  .tmt__cite {
    margin-top: 22px; padding-top: 18px; border-top: 1px solid var(--ink-10);
    display: flex; flex-direction: column; gap: 3px;
  }
  .tmt__name { font-size: 14px; font-weight: 500; color: var(--navy); }
  .tmt__ctx { font-size: 11.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-deep); }
</style>
