---
// Trust belt — sits directly below the hero, before section 02.
// Left zone: brand line (hidden on mobile). Right zone: auto-scrolling seals.
// Honesty: these are RE/MAX Portugal (network) awards.
import { awards as defaultAwards, awardsBeltCopy } from '../data/awards';
import type { Award } from '../data/awards';

interface Props {
  awards?: Award[];
}
const { awards = defaultAwards } = Astro.props;

// Two copies of the list make the marquee loop seamlessly (translateX -50%).
const loop = [...awards, ...awards];
---

<section class="abelt on-navy">
  <div class="abelt__inner">
    <div class="abelt__left">
      <p class="abelt__eyebrow">{awardsBeltCopy.eyebrow}</p>
      <p class="abelt__tag">{awardsBeltCopy.tagline}</p>
    </div>

    <span class="abelt__sep" aria-hidden="true"></span>

    <div
      class="abelt__viewport"
      role="group"
      aria-label={awardsBeltCopy.ariaLabel}
      aria-live="off"
    >
      <button type="button" class="abelt__pause" data-abelt-pause aria-pressed="false">
        Pausar prémios
      </button>
      <ul class="abelt__track" data-abelt-track>
        {loop.map((a, i) => (
          <li class="abelt__item" aria-hidden={i >= awards.length ? 'true' : undefined}>
            {a.image ? (
              <img
                class="abelt__seal"
                src={`${a.image}.webp`}
                alt={`${a.name} ${a.year} — distinção RE/MAX Portugal`}
                height="44"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <span class="abelt__lockup" title={`${a.name} ${a.year} — RE/MAX Portugal`}>
                <span class="abelt__lockup-name">{a.name}</span>
                <span class="abelt__lockup-meta">{a.issuer} · ’{a.year.slice(2)}</span>
              </span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .abelt {
    background: var(--navy);
    border-top: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
    padding-block: 28px;
    overflow: hidden;
  }
  .abelt__inner {
    max-width: var(--max);
    margin: 0 auto;
    padding-inline: var(--gutter);
    display: grid;
    grid-template-columns: 40% 1px 1fr;
    align-items: center;
    gap: clamp(20px, 3vw, 40px);
  }

  /* Left zone */
  .abelt__left { min-width: 0; }
  .abelt__eyebrow {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold-light);
  }
  .abelt__tag {
    margin: 6px 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    line-height: 1.3;
    color: var(--cream);
  }

  /* Separator */
  .abelt__sep {
    width: 1px;
    height: 32px;
    background: color-mix(in srgb, var(--gold) 20%, transparent);
    justify-self: center;
  }

  /* Right zone — marquee */
  .abelt__viewport { position: relative; overflow: hidden; min-width: 0; }
  .abelt__viewport::before,
  .abelt__viewport::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 48px;
    z-index: 2;
    pointer-events: none;
  }
  .abelt__viewport::before { left: 0; background: linear-gradient(90deg, var(--navy), transparent); }
  .abelt__viewport::after { right: 0; background: linear-gradient(270deg, var(--navy), transparent); }

  .abelt__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 40px;
    width: max-content;
    animation: abelt-scroll 30s linear infinite;
  }
  .abelt__track.is-paused { animation-play-state: paused; }

  @keyframes abelt-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .abelt__item { flex: 0 0 auto; display: flex; align-items: center; }
  .abelt__seal {
    height: 44px;
    width: auto;
    object-fit: contain;
    filter: brightness(1);
    transition: filter var(--t-fast);
  }
  .abelt__seal:hover { filter: brightness(1.1); }

  /* Text fallback lockup (until real seals are on disk) */
  .abelt__lockup {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 44px;
    padding: 0 18px;
    border: 1px solid var(--hairline-gold);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition: border-color var(--t-fast);
  }
  .abelt__lockup:hover { border-color: var(--hairline-gold-strong); }
  .abelt__lockup-name {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.1;
    color: var(--cream);
  }
  .abelt__lockup-meta {
    font-family: var(--font-sans);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-light);
    margin-top: 2px;
  }

  /* Keyboard pause button — appears on focus */
  .abelt__pause {
    position: absolute;
    z-index: 3;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 6px 14px;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--navy-ink);
    background: var(--gold-light);
    border: 0;
    border-radius: 100px;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
  }
  .abelt__pause:focus-visible {
    opacity: 1;
    pointer-events: auto;
    outline: 2px solid var(--cream);
    outline-offset: 2px;
  }

  /* Mobile: hide left zone + separator, full-width marquee */
  @media (max-width: 767px) {
    .abelt { padding-block: 20px; }
    .abelt__inner { grid-template-columns: 1fr; }
    .abelt__left,
    .abelt__sep { display: none; }
    .abelt__track { gap: 28px; animation-duration: 20s; }
    .abelt__seal { height: 36px; }
    .abelt__lockup { height: 36px; padding: 0 14px; }
    .abelt__lockup-name { font-size: 12px; }
  }

  /* Reduced motion: stop the marquee, show a static, centered row */
  @media (prefers-reduced-motion: reduce) {
    .abelt__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 16px 28px;
    }
    .abelt__item[aria-hidden='true'] { display: none; }
    .abelt__viewport::before,
    .abelt__viewport::after { display: none; }
  }
</style>

<script>
  // Keyboard-accessible pause toggle. The marquee never pauses on hover (by design),
  // but keyboard users get an explicit control that appears on focus.
  document.querySelectorAll<HTMLButtonElement>('[data-abelt-pause]').forEach((btn) => {
    const track = btn.parentElement?.querySelector<HTMLElement>('[data-abelt-track]');
    if (!track) return;
    btn.addEventListener('click', () => {
      const paused = track.classList.toggle('is-paused');
      btn.setAttribute('aria-pressed', String(paused));
      btn.textContent = paused ? 'Retomar prémios' : 'Pausar prémios';
    });
  });
</script>
