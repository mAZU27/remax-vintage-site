---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ValueSimulator from '../components/ValueSimulator.astro';
import CustomerSupport from '../components/CustomerSupport.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Homepage sits over a dark video hero → nav starts transparent. */
  overHeroNav?: boolean;
  noindex?: boolean;
  /** Preload an above-the-fold hero image (LCP). Emits <link rel=preload as=image>. */
  heroPreload?: { href: string; srcset?: string; sizes?: string };
}
const {
  title,
  description = site.description,
  image = '/media/hero-poster.jpg',
  overHeroNav = false,
  noindex = false,
  heroPreload,
} = Astro.props;

const pageTitle = title ? `${title} · ${site.shortName}` : `${site.name} — ${site.tagline}`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImage = Astro.site ? new URL(image, Astro.site).href : image;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: site.name,
  description: site.description,
  image: Astro.site ? new URL(site.logo, Astro.site).href : site.logo,
  url: Astro.site ? Astro.site.href : undefined,
  telephone: site.phone,
  email: site.email,
  areaServed: 'Porto, Portugal',
  address: { '@type': 'PostalAddress', addressLocality: 'Porto', addressCountry: 'PT' },
  priceRange: '€€€€',
  foundingDate: String(site.established),
  sameAs: site.social.map((s) => s.href).filter((h) => h && h !== '#'),
};
---
<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#0B1A2E" />
    <meta name="color-scheme" content="light" />

    {heroPreload && (
      <link
        rel="preload"
        as="image"
        href={heroPreload.href}
        imagesrcset={heroPreload.srcset}
        imagesizes={heroPreload.sizes}
        fetchpriority="high"
      />
    )}

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="pt_PT" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@400;500&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Saltar para o conteúdo</a>
    <span id="top"></span>
    <Nav overHero={overHeroNav} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <ValueSimulator />
    <CustomerSupport />

    <script>
      // Reveal-on-scroll — single observer for every [data-reveal] on the page.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const items = document.querySelectorAll('[data-reveal]');
      if (reduce || !('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-in');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.12 }
        );
        items.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
